/* OUTERSTELLAR — all tuning lives here. */
const CFG = {
  render: { maxW: 1280, maxH: 720, pixelRatio: 1.5, fog: 0.0009 },

  qte: {
    tap:      { hit: 220, perfect: 70, lead: 1100 },   // ms
    swipe:    { window: 650, lead: 1000 },
    hold:     { bandPct: 0.26, perfectPct: 0.09, lead: 900 },
    mash:     { minTaps: 8, maxTaps: 16, slowDur: 2200, fastDur: 1400, lead: 700 },
    sequence: { minTargets: 2, maxTargets: 4, per: 500, lead: 900 }
  },

  score: {
    goal: 1000,        // points needed to clear a stage
    perfectBonus: 0.15 // a perfect is worth 15% more than the per-action share
  },

  grade: { S: 95, A: 85, B: 70 },

  tempo: { start: 1600, end: 700 },   // beat interval eases across the run

  hull: { max: 4 },                    // life out of 4, persists across stages; 0 = full restart

  boss: {
    magpie: { hp: 8,  telegraphStart: 900, telegraphEnd: 550, volley: 3 },
    warden: { hp: [6, 8], telegraphStart: 850, telegraphEnd: 520, volley: 2 }
  },

  palettes: {
    suit:  ['#e8eaee','#f0a500','#2f6fed','#d94f4f','#3fb47a','#8a5cd6','#1b1e26','#d9c7a3'],
    visor: ['#ffb648','#7fd6ff','#101318','#c9f26b'],
    ship:  ['#d7dbe2','#e0563f','#2b6cb0','#f2c14e','#2f9e6f','#8f5bd0','#20242c','#c98a5b'],
    flame: ['#7fd6ff','#ff9b3d','#c9f26b']
  },
  accessories: ['none','antenna','headphones','fin','sticker'],
  bodies: ['classic','stubby','needle','retro'],

  defaults: {
