/* ===== src/qte.js ===== */
/* QTE engine: schedules beats, renders DOM prompts anchored to projected 3D targets,
   resolves PERFECT / HIT / MISS(EARLY|LATE), tracks combo, emits score events. */
const QTE = (() => {
  const ARROWS = { up: '↑', down: '↓', left: '←', right: '→' };

  function create(opts) {
    const layer = document.getElementById('prompts');
    const camera = opts.camera;
    const project = opts.project;      // (worldVec3) -> {x,y} px
    const onEvent = opts.onEvent;      // (kind, beat, meta)

    let beats = [];        // pending
    let live = [];         // on screen
    let clock = 0;
    let running = false;
    let combo = 0, best = 0;
    const tally = { perfect: 0, hit: 0, miss: 0, total: 0 };

    function reset(list) {
      live.forEach(b => b.el && b.el.remove());
      live = [];
      beats = list.map((b, i) => Object.assign({ id: i, done: false }, b));
      clock = 0; combo = 0; best = 0;
      tally.perfect = tally.hit = tally.miss = 0;
      tally.total = beats.length;
      running = true;
    }

    function windowFor(b) {
      const q = CFG.qte;
      if (b.type === 'tap') return q.tap.hit;
      if (b.type === 'swipe') return q.swipe.window / 2;
      return b.window || 400;
    }
    function leadFor(b) {
      const q = CFG.qte;
      return b.lead || (
        b.type === 'tap' ? q.tap.lead :
        b.type === 'swipe' ? q.swipe.lead :
        b.type === 'hold' ? q.hold.lead :
        b.type === 'mash' ? q.mash.lead : q.sequence.lead
      );
    }

    function spawn(b) {
      const el = document.createElement('div');
      el.className = 'prompt' + (b.danger ? ' danger' : '');
      const ring = document.createElement('div');
      ring.className = 'ring';
      el.appendChild(ring);

      if (b.type === 'swipe') {
        const a = document.createElement('div');
        a.className = 'arrow';
        a.textContent = ARROWS[b.dir];
        el.appendChild(a);
      } else if (b.type === 'hold') {
        const c = document.createElement('div');
        c.className = 'core';
        c.textContent = b.label || 'HOLD';
        el.appendChild(c);
        const bar = document.createElement('div');
        bar.className = 'holdbar';
        const band = document.createElement('div');
        band.className = 'holdband';
        const bandW = CFG.qte.hold.bandPct * 100;
        band.style.left = (100 - bandW) + '%';
        band.style.width = bandW + '%';
        const fill = document.createElement('i');
        bar.appendChild(band); bar.appendChild(fill);
        el.appendChild(bar);
        b.fill = fill;
      } else if (b.type === 'mash') {
        const c = document.createElement('div');
        c.className = 'core';
        c.textContent = b.label || 'MASH';
        el.appendChild(c);
        const m = document.createElement('div');
        m.className = 'mashcount';
        el.appendChild(m);
        b.counter = m;
        b.taps = 0;
      } else {
        const c = document.createElement('div');
        c.className = 'core';
        c.textContent = b.label || 'TAP';
        el.appendChild(c);
      }

      b.el = el; b.ring = ring;
      b.state = 'in';       // in → active(hold/mash) → resolved
      b.holding = false;
      b.holdT = 0;
      layer.appendChild(el);
      live.push(b);
      AUDIO.whoosh();
    }

    function place(b) {
      const p = project(b.target || opts.defaultTarget());
      // clamp to the safe area: prompts must never hang off an edge
      const W = window.innerWidth, H = window.innerHeight;
      p.x = Math.max(W * 0.14, Math.min(W * 0.86, p.x));
      p.y = Math.max(H * 0.18, Math.min(H * 0.74, p.y));
      b.el.style.left = p.x + 'px';
      b.el.style.top = p.y + 'px';
      b.px = p;
    }

    function resolve(b, kind, meta) {
      if (b.state === 'resolved') return;
      b.state = 'resolved';
      b.done = true;

      if (kind === 'miss') {
        combo = 0;
        tally.miss++;
        b.el.classList.add('missfx', 'out');
        AUDIO.miss();
        FX.kick(0.35);
      } else {
        combo++;
        best = Math.max(best, combo);
        if (kind === 'perfect') { tally.perfect++; AUDIO.perfect(combo); b.el.classList.add('perfectfx', 'out'); FX.flash(0.16, 90); }
        else { tally.hit++; AUDIO.hit(combo); b.el.classList.add('hitfx', 'out'); }
        FX.kick(kind === 'perfect' ? 0.22 : 0.12);
        FX.freeze(kind === 'perfect' ? 60 : 35);
      }
      try { onEvent(kind, b, Object.assign({ combo, best }, meta || {})); }
      catch (e) { console.error('onEvent:', e && e.message); }
      setTimeout(() => { b.el && b.el.remove(); }, 240);
      const i = live.indexOf(b);
      if (i >= 0) live.splice(i, 1);
    }

    // find the front-most unresolved beat expecting input
    function front(type) {
      for (const b of live) {
        if (b.state === 'resolved') continue;
        if (type && b.type !== type) continue;
        return b;
      }
      return null;
    }

    function handle(kind, data) {
      if (!running) return;

      if (kind === 'swipe') {
        const b = front('swipe');
        if (!b) { punish(); return; }
        const off = Math.abs(clock - b.t);
        if (off > CFG.qte.swipe.window) return;
        if (data.dir !== b.dir) { resolve(b, 'miss', { why: 'wrong' }); return; }
        resolve(b, off < 140 ? 'perfect' : 'hit', {});
        return;
      }

      if (kind === 'down') {
        const h = front('hold');
        if (h && h.state === 'in' && clock >= h.t - 300) { h.holding = true; h.state = 'active'; }
        return;
      }

      if (kind === 'mash') {
        const m = front('mash');
        if (m && m.state !== 'resolved' && clock >= m.t) {
          m.state = 'active';
          m.taps++;
          AUDIO.mash();
          m.counter.textContent = m.taps + ' / ' + m.need;
          m.el.style.transform = 'translate(-50%,-50%) scale(' + (1 + Math.min(0.18, m.taps * 0.012)) + ')';
          if (m.taps >= m.need) resolve(m, 'perfect', {});
        }
        return;
      }

      if (kind === 'up') {
        const h = live.find(b => b.type === 'hold' && b.holding && b.state !== 'resolved');
        if (h) {
          h.holding = false;
          const k = h.holdT / h.dur;   // fraction of required duration held
          const band = CFG.qte.hold.bandPct, perf = CFG.qte.hold.perfectPct;
          const off = Math.abs(k - 1);
          if (off <= perf) resolve(h, 'perfect', {});
          else if (off <= band) resolve(h, 'hit', {});
          else resolve(h, 'miss', { why: k < 1 ? 'early' : 'late' });
          return;
        }
      }

      if (kind === 'tap') {
        const b = front();
        if (!b) { punish(); return; }
        if (b.type === 'hold' || b.type === 'mash') return;   // handled above
        if (b.type === 'swipe') { resolve(b, 'miss', { why: 'wrong' }); return; }
        // tap / sequence step
        const off = clock - b.t;
        const q = CFG.qte.tap;
        if (off < -q.hit) { punish(); return; }   // way early: don't consume
        if (Math.abs(off) <= q.perfect) resolve(b, 'perfect', {});
        else if (Math.abs(off) <= q.hit) resolve(b, 'hit', { why: off < 0 ? 'early' : 'late' });
        else resolve(b, 'miss', { why: off < 0 ? 'early' : 'late' });
      }
    }

    let punishCool = 0;
    function punish() {
      if (punishCool > 0) return;
      punishCool = 0.35;
      AUDIO.miss();
      FX.kick(0.1);
    }

    function update(dt) {
      if (!running) return;
      clock += dt * 1000;
      if (punishCool > 0) punishCool -= dt;

      // spawn
      for (const b of beats) {
        if (b.spawned || b.done) continue;
        if (clock >= b.t - leadFor(b)) {
          b.spawned = true;
          if (b.type === 'mash') {
            b.need = b.need || CFG.qte.mash.minTaps;
            b.dur = b.dur || CFG.qte.mash.slowDur;
          }
          spawn(b);
        }
      }

      // animate + timeout — one bad beat must not stall the rest
      for (let i = live.length - 1; i >= 0; i--) {
        const b = live[i];
        if (b.state === 'resolved') continue;
        try { place(b); } catch (e) { continue; }

        const lead = leadFor(b);
        const approach = Math.min(1, Math.max(0, (clock - (b.t - lead)) / lead));

        if (b.type === 'tap' || b.type === 'swipe' || b.type === 'sequence') {
          const s = 2.2 - 1.2 * approach;   // shrink ring toward 1.0 at beat time
          b.ring.style.transform = `scale(${Math.max(0.9, s)})`;
          b.ring.classList.toggle('shrink', approach > 0.75);
          b.el.style.opacity = Math.min(1, approach * 2.2);
          const late = b.type === 'swipe' ? CFG.qte.swipe.window : CFG.qte.tap.hit;
          if (clock > b.t + late) resolve(b, 'miss', { why: 'late' });
        }

        if (b.type === 'hold') {
          b.ring.style.transform = `scale(${Math.max(1, 2.0 - 1.0 * approach)})`;
          b.el.style.opacity = Math.min(1, approach * 2.2);
          if (b.holding) {
            b.holdT += dt * 1000;
            const k = Math.min(1.35, b.holdT / b.dur);
            b.fill.style.width = (k / 1.35 * 100) + '%';
            if (k >= 1.35) {   // held way too long
              b.holding = false;
              resolve(b, 'miss', { why: 'late' });
            }
          } else if (b.state === 'in' && clock > b.t + 500) {
            resolve(b, 'miss', { why: 'no input' });
          }
        }

        if (b.type === 'mash') {
          b.ring.style.transform = `scale(${Math.max(1, 2.0 - 1.0 * approach)})`;
          b.el.style.opacity = Math.min(1, approach * 2.2);
          if (!b.counter.textContent) b.counter.textContent = '0 / ' + b.need;
          if (clock > b.t + b.dur) {
            if (b.taps >= b.need * 0.6) resolve(b, 'hit', {});
            else resolve(b, 'miss', { why: 'too slow' });
          }
        }
      }
    }

    function finished() {
      return running && beats.every(b => b.done) && live.length === 0;
    }

    // boss fights push beats in live, timed against the engine clock
    function appendBeats(list) {
      list.forEach(b => {
        b.id = beats.length; b.done = false; b.spawned = false;
        beats.push(b);          // by reference — the boss watches b.done
        tally.total++;
      });
    }

    return {
      reset, update, handle, finished, appendBeats,
      stop() { running = false; live.forEach(b => b.el && b.el.remove()); live = []; },
      get combo() { return combo; },
      get bestCombo() { return best; },
      get tally() { return tally; },
      get clock() { return clock; },
      get liveBeats() { return live; },
      resolveExternal: resolve,
      hitRate() {
        const n = tally.perfect + tally.hit + tally.miss;
        return n ? Math.round(((tally.perfect + tally.hit) / n) * 100) : 0;
      },
      mult() {
        const s = CFG.score;
        return Math.min(s.multCap, 1 + s.comboStep * Math.min(combo, s.comboCap));
      }
    };
  }

  return { create };
})();

/* ===== src/levels.js ===== */
/* Data-driven stages. Beat interval eases 1.6s → 0.7s across the run. */
const LEVELS = (() => {
  const DIRS = ['up', 'down', 'left', 'right'];
  // deterministic-ish shuffle so a stage plays the same on retry
  function rng(seed) {
    let s = seed >>> 0;
    return () => ((s = (s * 1664525 + 1013904223) >>> 0) / 4294967296);
  }

  // interval at global progress p (0..1)
  function interval(p) {
    const t = CFG.tempo;
    return t.start + (t.end - t.start) * (p * p * (3 - 2 * p)); // smoothstep
  }

  function spread(a, b) { return { a, b }; }

  // Build beats for one stage. p0..p1 = its slice of the run's tempo ramp.
  function make(stageIdx, count, kinds, seed, p0, p1) {
    const r = rng(seed);
    const beats = [];
    let t = 1200;
    for (let i = 0; i < count; i++) {
      const p = p0 + (p1 - p0) * (i / Math.max(1, count - 1));
      const gap = interval(p);
      const kind = kinds[Math.floor(r() * kinds.length)];
      const b = { t, type: kind, slot: i % 5 };
      if (kind === 'swipe') b.dir = DIRS[Math.floor(r() * 4)];
      if (kind === 'hold') {
        b.dur = 700 + Math.floor(r() * 700);
        b.label = 'HOLD';
        t += b.dur;   // holds eat real time
      }
      if (kind === 'mash') {
        const q = CFG.qte.mash;
        b.need = q.minTaps + Math.floor(r() * (q.maxTaps - q.minTaps + 1));
        b.dur = Math.round(q.slowDur + (q.fastDur - q.slowDur) * p);
        b.label = 'MASH';
        t += b.dur;
      }
      if (kind === 'sequence') {
        // expand a sequence into 2–4 quick taps
        const n = CFG.qte.sequence.minTargets + Math.floor(r() * (CFG.qte.sequence.maxTargets - CFG.qte.sequence.minTargets + 1));
        for (let k = 0; k < n; k++) {
          beats.push({ t: t + k * CFG.qte.sequence.per, type: 'tap', label: (k + 1) + '/' + n, slot: (i + k) % 5, lead: 700 });
        }
        t += n * CFG.qte.sequence.per + gap * 0.7;
        continue;
      }
      beats.push(b);
      t += gap;
    }
    return beats;
  }

  const STAGES = [
    {
      n: 1, name: 'IGNITION', kind: 'run',
      radio: 'Ignition in three. Two. …I forgot one. Just hit the beats.',
      beats: () => make(1, 5, ['tap', 'tap', 'hold'], 11, 0.00, 0.22),
      cam: { z: 8.5, y: 1.2 }
    },
    {
      n: 2, name: 'DEBRIS BELT', kind: 'run',
      radio: "Rock field. Big ones, small ones. Mostly big ones. Swipe or become debris.",
      beats: () => make(2, 5, ['swipe', 'swipe', 'tap', 'tap'], 23, 0.22, 0.5),
      cam: { z: 9.5, y: 0.8 }
    },
    {
      n: 3, name: 'RE-ENTRY', kind: 'run',
      radio: "Heat shield is 'optional' according to the manual. The manual is on fire.",
      beats: () => make(3, 5, ['mash', 'tap', 'tap', 'swipe'], 53, 0.5, 0.78),
      cam: { z: 8, y: 0.6 }
    },
    {
      n: 4, name: 'WARDEN', kind: 'boss', boss: 'warden',
      radio: 'Orbital guardian. Old. Patient. Extremely armed. Be rude.',
      cam: { z: 11, y: 1.2 }
    },
    {
      n: 5, name: 'APPROACH', kind: 'orbit',
      radio: 'Ten gravity wells between you and the ground. Tap to let go on the tangent. Miss and the sky keeps you.',
      cam: { z: 9, y: 1.0 }
    }
  ];

  return { STAGES, interval, make };
})();

