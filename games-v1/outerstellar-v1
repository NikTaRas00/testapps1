<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, user-scalable=no">
<title>OUTERSTELLAR</title>
<style>
:root{
  --ink:#f2f4f7; --dim:#8b93a1; --line:rgba(255,255,255,.14);
  --hit:#7fd6ff; --perfect:#ffd76b; --miss:#ff5f6b; --warn:#ff8a5c;
  --pad:clamp(12px,2.4vmin,22px);
  --micro:.62rem;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;background:#000;overflow:hidden}
body{
  font-family:system-ui,-apple-system,"Segoe UI",Roboto,sans-serif;
  color:var(--ink);touch-action:none;user-select:none;-webkit-user-select:none;
  display:grid;place-items:center;
}
#stage{position:relative;width:100vw;height:100vh;height:100dvh;overflow:hidden;background:#000}
#view{position:absolute;inset:0;width:100%;height:100%;display:block}

#vignette{position:absolute;inset:0;pointer-events:none;
  background:radial-gradient(ellipse at 50% 48%,transparent 42%,rgba(0,0,0,.55) 100%);}
#grain{position:absolute;inset:-50%;pointer-events:none;opacity:.05;
  background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='120' height='120'><filter id='n'><feTurbulence baseFrequency='.8' numOctaves='2'/></filter><rect width='120' height='120' filter='url(%23n)'/></svg>");
  animation:grain 1.1s steps(4) infinite;}
@keyframes grain{0%{transform:translate(0,0)}25%{transform:translate(-3%,2%)}50%{transform:translate(2%,-3%)}75%{transform:translate(-2%,-2%)}100%{transform:translate(0,0)}}

/* ---------- typographic HUD ---------- */
.hidden{display:none !important}
#hud{position:absolute;inset:0;pointer-events:none;padding:var(--pad);
  display:flex;flex-direction:column;gap:0}
.hud-row{display:flex;justify-content:space-between;align-items:flex-start;gap:12px}
.hud-row.top{justify-content:center}
.hud-stage{text-align:center;display:flex;flex-direction:column;gap:2px;
  background:rgba(4,8,12,.35);border:1px solid var(--line);border-radius:5px;
  padding:6px 16px;backdrop-filter:blur(3px)}
.hud-stage .lbl{font-size:var(--micro);letter-spacing:.22em;text-transform:uppercase;color:var(--dim);font-weight:700}
.hud-stage .val{font-size:clamp(13px,2vmin,17px);font-weight:900;letter-spacing:.18em}
.hud-row.mid{justify-content:center;flex:1;align-items:flex-start;padding-top:2vh;padding-bottom:110px}
.hud-block{min-width:78px}
.hud-block.center{text-align:center;flex:1}
.hud-block.right{text-align:right}
.lbl{font-size:var(--micro);letter-spacing:.22em;text-transform:uppercase;color:var(--dim);font-weight:700}
.val{font-size:clamp(20px,3.4vmin,30px);font-weight:900;letter-spacing:-.02em;font-variant-numeric:tabular-nums;line-height:1.1}
.val.small{font-size:clamp(13px,2vmin,17px);letter-spacing:.18em}
.mult{font-size:.55em;letter-spacing:0;color:var(--hit);margin-left:.35em;font-weight:800}
#hud-combo.hot{color:var(--perfect);text-shadow:0 0 18px rgba(255,215,107,.5)}

#boss-bar{width:min(58%,420px);text-align:center}
.boss-name{font-size:var(--micro);letter-spacing:.34em;font-weight:800;color:var(--warn);margin-bottom:6px}
.boss-track{height:5px;background:rgba(255,255,255,.1);overflow:hidden}
.boss-fill{height:100%;width:100%;background:var(--warn);transform-origin:left;transition:width .18s ease-out}
.boss-phase{font-size:var(--micro);letter-spacing:.22em;color:var(--dim);margin-top:6px;font-weight:700;min-height:1em}

.hull{width:100%}
.hull-track{height:6px;border-radius:4px;background:rgba(255,255,255,.1);margin-top:5px;overflow:hidden}
.hull-fill{height:100%;width:100%;border-radius:4px;background:linear-gradient(90deg,#3aa5e0,var(--hit));transition:width .25s}
.hull-fill.low{background:var(--miss)}
.hud-dock{position:absolute;left:0;right:0;bottom:0;padding:0 var(--pad);
  padding-bottom:calc(var(--pad) + env(safe-area-inset-bottom,0px));
  display:flex;flex-direction:column;gap:12px}
.scorebar{width:100%}
.scorebar-label{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:5px;
  font:800 var(--micro)/1 system-ui;letter-spacing:.18em;text-transform:uppercase;color:var(--dim)}
#scorebar-num{color:var(--hit);font-variant-numeric:tabular-nums}
.progress{position:relative;height:8px;border-radius:5px;background:rgba(255,255,255,.09);
  overflow:hidden;box-shadow:inset 0 0 0 1px rgba(255,255,255,.08)}
.progress-fill{height:100%;width:0;border-radius:5px;
  background:linear-gradient(90deg,#3aa5e0,var(--hit));
  box-shadow:0 0 12px rgba(127,214,255,.6);transition:width .25s cubic-bezier(.2,.8,.2,1)}
.progress-fill.full{background:linear-gradient(90deg,var(--perfect),#fff);
  box-shadow:0 0 18px rgba(255,215,107,.8)}
.goalsuffix{font-size:.5em;letter-spacing:0;color:var(--dim);margin-left:.15em;font-weight:700}

.ghost-btn{pointer-events:auto;background:rgba(4,8,12,.4);border:1px solid var(--line);color:var(--dim);
  font:800 var(--micro)/1 system-ui;letter-spacing:.2em;padding:6px 10px;cursor:pointer;opacity:.6;
  border-radius:4px;backdrop-filter:blur(3px)}
#mute.ghost-btn{position:absolute;right:var(--pad);top:calc(var(--pad) + 64px);bottom:auto}
.ghost-btn:hover{color:var(--ink);border-color:var(--ink)}

/* ---------- QTE prompts ---------- */
#prompts,#floats{position:absolute;inset:0;pointer-events:none;z-index:4}
.prompt{position:absolute;transform:translate(-50%,-50%);display:grid;place-items:center;
  width:112px;height:112px}
.ring{position:absolute;inset:0;border:2px solid var(--ink);border-radius:50%;opacity:.9}
.ring.shrink{border-color:var(--hit)}
.core{font-size:var(--micro);font-weight:900;letter-spacing:.2em;text-align:center;line-height:1.4;z-index:2}
.arrow{font-size:34px;font-weight:900;line-height:1;z-index:2}
.prompt.hitfx .ring{border-color:var(--hit);box-shadow:0 0 26px rgba(127,214,255,.6)}
.prompt.perfectfx .ring{border-color:var(--perfect);box-shadow:0 0 34px rgba(255,215,107,.75)}
.prompt.missfx .ring{border-color:var(--miss);opacity:.6}
.prompt.out{animation:pop .22s ease-out forwards}
@keyframes pop{to{transform:translate(-50%,-50%) scale(1.5);opacity:0}}
.holdbar{position:absolute;bottom:-16px;left:8%;width:84%;height:3px;background:rgba(255,255,255,.16)}
.holdbar i{display:block;height:100%;width:0;background:var(--hit)}
.holdband{position:absolute;top:0;height:100%;background:var(--perfect);opacity:.55}
.mashcount{position:absolute;bottom:-22px;left:0;right:0;text-align:center;
  font:900 12px system-ui;letter-spacing:.14em;color:var(--dim)}
.prompt.danger .ring{border-color:var(--warn)}

.float{position:absolute;transform:translate(-50%,-50%);font-weight:900;font-size:20px;
  letter-spacing:.02em;animation:rise .8s ease-out forwards;text-shadow:0 2px 14px #000}
@keyframes rise{to{transform:translate(-50%,-160%);opacity:0}}
.float.hit{color:var(--hit)}.float.perfect{color:var(--perfect);font-size:24px}
.float.miss{color:var(--miss)}

/* ---------- overlays ---------- */
.overlay{position:absolute;inset:0;display:grid;place-items:center;padding:24px;
  background:radial-gradient(ellipse at 50% 50%,rgba(4,6,12,.72),rgba(0,0,0,.92));
  backdrop-filter:blur(2px);z-index:5;animation:fade .3s ease-out}
.overlay.solid{background:radial-gradient(ellipse at 50% 30%,#0b1420,#04070c 70%);backdrop-filter:none}
@keyframes fade{from{opacity:0}}
.eyebrow{font-size:var(--micro);letter-spacing:.34em;text-transform:uppercase;color:var(--dim);font-weight:800}
.eyebrow.warn{color:var(--miss)}
.title{font-size:clamp(38px,9vmin,86px);font-weight:900;letter-spacing:-.03em;margin:14px 0 10px}
.title span{color:var(--dim)}
.boot-inner,.intro-inner{text-align:center;max-width:520px}
.sub{color:var(--dim);line-height:1.6;max-width:34ch;margin:0 auto 26px;font-size:15px}
.hint{margin-top:18px;font-size:var(--micro);letter-spacing:.16em;color:var(--dim);font-weight:700}

button{font-family:inherit;cursor:pointer}
.primary{background:var(--ink);color:#04060c;border:0;padding:15px 30px;
  font:900 13px/1 system-ui;letter-spacing:.2em;text-transform:uppercase;transition:transform .12s}
.primary:hover{transform:translateY(-2px)}
.primary:active{transform:translateY(0)}
.ghost{background:none;border:1px solid var(--line);color:var(--ink);padding:15px 24px;
  font:800 13px/1 system-ui;letter-spacing:.2em;text-transform:uppercase}
.ghost:hover{border-color:var(--ink)}
button:focus-visible,.tab:focus-visible,.sw:focus-visible,.chip:focus-visible{outline:2px solid var(--hit);outline-offset:3px}

/* hangar */
#hangar{background:linear-gradient(to right,rgba(0,0,0,.9) 0%,rgba(0,0,0,.2) 55%,transparent 100%);
  place-items:center start;padding-left:clamp(20px,6vw,64px)}
.hangar-panel{width:min(340px,86vw)}
.hangar-panel h2{font-size:clamp(26px,4.4vmin,38px);font-weight:900;letter-spacing:-.02em;margin:8px 0 20px}
.tabs{display:flex;gap:2px;margin-bottom:20px;border-bottom:1px solid var(--line)}
.tab{background:none;border:0;color:var(--dim);padding:9px 14px;
  font:800 var(--micro)/1 system-ui;letter-spacing:.2em;text-transform:uppercase;border-bottom:2px solid transparent;margin-bottom:-1px}
.tab.active{color:var(--ink);border-bottom-color:var(--ink)}
.row{display:flex;align-items:center;gap:14px;margin-bottom:18px}
.row-lbl{font-size:var(--micro);letter-spacing:.2em;text-transform:uppercase;color:var(--dim);font-weight:800;width:52px;flex:none}
.swatches{display:flex;flex-wrap:wrap;gap:8px}
.sw{width:26px;height:26px;border-radius:50%;border:2px solid transparent;background:#333;padding:0;
  box-shadow:inset 0 0 0 1px rgba(0,0,0,.5)}
.sw.on{border-color:var(--ink);transform:scale(1.12)}
.chips{display:flex;flex-wrap:wrap;gap:6px}
.chip{background:none;border:1px solid var(--line);color:var(--dim);padding:7px 10px;
  font:800 var(--micro)/1 system-ui;letter-spacing:.12em;text-transform:uppercase}
.chip.on{color:#04060c;background:var(--ink);border-color:var(--ink)}
#btn-launch{margin-top:8px;width:100%}

/* intro */
.intro-name{font-size:clamp(34px,7.5vmin,68px);font-weight:900;letter-spacing:-.02em;margin:10px 0 16px}
.radio{color:var(--dim);font-size:14px;line-height:1.6;font-style:italic;max-width:32ch;margin:0 auto}
.radio:before{content:"“"}.radio:after{content:"”"}

/* results */
.results-card{width:min(400px,90vw);background:linear-gradient(180deg,rgba(14,22,32,.96),rgba(6,11,16,.98));
  border:1px solid var(--line);border-radius:12px;padding:22px 22px 20px;
  box-shadow:0 24px 60px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,255,255,.05)}
.res-head{display:flex;align-items:center;justify-content:space-between;gap:14px;margin-bottom:18px}
.res-head .eyebrow{text-align:left;flex:1}
.res-grade-badge{flex:none;width:64px;height:64px;border-radius:12px;display:grid;place-items:center;
  font-size:38px;font-weight:900;letter-spacing:-.04em;
  background:rgba(255,255,255,.05);border:1px solid var(--line)}
.res-grade-badge[data-g="S"]{color:var(--perfect);border-color:rgba(255,215,107,.5);box-shadow:0 0 24px rgba(255,215,107,.25)}
.res-grade-badge[data-g="A"]{color:var(--hit);border-color:rgba(127,214,255,.5);box-shadow:0 0 24px rgba(127,214,255,.2)}
.res-grade-badge[data-g="B"]{color:var(--ink)}
.res-grade-badge[data-g="C"]{color:var(--dim)}
.results-inner{text-align:center;width:min(420px,90vw)}
.results-inner.wide{width:min(520px,92vw)}
.grade{font-size:clamp(80px,17vmin,150px);font-weight:900;line-height:.9;margin:6px 0 18px;letter-spacing:-.05em}
.grade[data-g="S"]{color:var(--perfect)}.grade[data-g="A"]{color:var(--hit)}
.grade[data-g="B"]{color:var(--ink)}.grade[data-g="C"]{color:var(--dim)}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:20px;
  border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:14px 0}
.stats dt{font-size:var(--micro);letter-spacing:.14em;text-transform:uppercase;color:var(--dim);font-weight:800;margin-bottom:5px}
.stats dd{font-size:19px;font-weight:900;font-variant-numeric:tabular-nums}
.score-line{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:24px}
.score-line span{font-size:var(--micro);letter-spacing:.2em;text-transform:uppercase;color:var(--dim);font-weight:800}
.score-line b{font-size:30px;font-weight:900;font-variant-numeric:tabular-nums}
.score-line.big b{font-size:44px}
.btn-row{display:flex;gap:10px}
.btn-row button{flex:1}
.tally-list{margin:20px 0;border-top:1px solid var(--line)}
.tally-row{display:flex;justify-content:space-between;align-items:center;padding:11px 0;border-bottom:1px solid var(--line);font-size:13px}
.tally-row .n{color:var(--dim);letter-spacing:.16em;font-weight:800;font-size:var(--micro);text-transform:uppercase}
.tally-row .g{font-weight:900;width:22px;text-align:center}
.tally-row .s{font-weight:900;font-variant-numeric:tabular-nums}
.best{font-size:var(--micro);letter-spacing:.22em;font-weight:800;color:var(--perfect);margin-bottom:18px;min-height:1em}
#btn-again{width:100%}

.shake{animation:shake .3s}
@keyframes shake{10%,90%{transform:translate(-1px,1px)}30%,70%{transform:translate(3px,-2px)}50%{transform:translate(-3px,2px)}}
#flash{position:absolute;inset:0;pointer-events:none;background:#fff;opacity:0}

@media (max-width:520px){
  .stats{grid-template-columns:repeat(2,1fr);gap:12px}
  .prompt{width:120px;height:120px}
  .arrow{font-size:42px}
}
@media (prefers-reduced-motion:reduce){
  *,*:before,*:after{animation-duration:.01ms !important;animation-iteration-count:1 !important;transition-duration:.01ms !important}
  #grain{display:none}
}

/* ---------- planetfall ---------- */
#walk-ui{position:absolute;inset:0;pointer-events:none;z-index:3}
.walk-leave{position:absolute;top:var(--pad);right:var(--pad);left:auto;bottom:auto;pointer-events:auto}
#boot .ghost{margin-top:10px}

/* top cluster: counters + current objective */
.walk-top{position:absolute;top:var(--pad);left:0;right:0;display:flex;flex-direction:column;
  align-items:center;gap:8px;padding:0 64px}
.walk-quest{display:flex;gap:16px;font:900 13px/1 system-ui;letter-spacing:.12em;
  color:var(--ink);text-shadow:0 1px 6px #000;font-variant-numeric:tabular-nums}
#wq-shards{color:var(--hit)}
#wq-rings{color:var(--perfect)}
#wq-score{color:var(--ink)}
.wq-objective{text-align:center;background:rgba(6,10,14,.5);border:1px solid var(--line);
  border-radius:4px;padding:7px 16px;backdrop-filter:blur(4px);max-width:min(86vw,420px);
  transition:opacity .3s}
.wq-obj-label{font:800 var(--micro)/1 system-ui;letter-spacing:.28em;color:var(--dim);margin-bottom:4px}
.wq-obj-text{font:700 13px/1.3 system-ui;letter-spacing:.02em;color:var(--ink)}
.wq-objective.flash{animation:objflash .6s ease}
@keyframes objflash{0%,100%{background:rgba(6,10,14,.5)}40%{background:rgba(127,214,255,.22)}}

/* directional pointer */
#compass{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  color:var(--hit);pointer-events:none;filter:drop-shadow(0 2px 8px rgba(0,0,0,.7));
  display:flex;flex-direction:column;align-items:center;gap:2px;opacity:.9;transition:opacity .3s}
#compass svg{display:block}
#compass-dist{font:900 11px/1 system-ui;letter-spacing:.1em;color:var(--ink);
  text-shadow:0 1px 4px #000;transform:rotate(0deg)}

/* proximity hint */
#walk-proximity{position:absolute;bottom:calc(var(--pad) + 132px);left:50%;transform:translateX(-50%);
  font:800 var(--micro)/1 system-ui;letter-spacing:.2em;color:var(--hit);white-space:nowrap;
  text-shadow:0 1px 8px #000;pointer-events:none;text-transform:uppercase}

/* pickup banner */
#walk-banner{position:absolute;top:30%;left:50%;transform:translate(-50%,-50%);
  font:900 clamp(20px,5.4vmin,34px)/1.2 system-ui;letter-spacing:.06em;text-align:center;
  color:var(--perfect);text-shadow:0 2px 20px rgba(255,215,107,.45),0 2px 8px #000;
  animation:bannerpop 2.4s ease forwards;pointer-events:none;white-space:pre-line}
@keyframes bannerpop{0%{opacity:0;transform:translate(-50%,-50%) scale(.8)}
  12%{opacity:1;transform:translate(-50%,-50%) scale(1.05)}
  20%{transform:translate(-50%,-50%) scale(1)}
  80%{opacity:1}100%{opacity:0}}

/* joystick + jump */
#joy-base{position:absolute;width:124px;height:124px;margin:-62px 0 0 -62px;border-radius:50%;
  border:2px solid rgba(255,255,255,.22);background:rgba(255,255,255,.04);pointer-events:none}
#joy-knob{position:absolute;left:50%;top:50%;width:54px;height:54px;margin:-27px 0 0 -27px;
  border-radius:50%;background:rgba(255,255,255,.85);box-shadow:0 2px 14px rgba(0,0,0,.5)}
#btn-jump{position:absolute;right:calc(var(--pad) + 4px);bottom:calc(var(--pad) + 26px);
  width:84px;height:84px;border-radius:50%;pointer-events:auto;cursor:pointer;
  border:2px solid rgba(255,255,255,.35);background:rgba(255,255,255,.08);color:var(--ink);
  font:900 12px/1 system-ui;letter-spacing:.2em;backdrop-filter:blur(2px);
  transition:transform .08s,background .08s}
#btn-jump:active{transform:scale(.92);background:rgba(255,255,255,.22)}

/* briefing + complete cards */
.walk-card{position:absolute;inset:0;margin:auto;width:min(400px,90vw);height:max-content;
  max-height:88vh;pointer-events:auto;background:linear-gradient(180deg,rgba(8,14,18,.94),rgba(4,8,10,.97));
  border:1px solid var(--line);border-radius:8px;padding:26px 24px;text-align:center;
  backdrop-filter:blur(6px);animation:fade .3s ease-out;overflow:auto}
.wc-title{font:900 clamp(22px,5vmin,30px)/1.15 system-ui;letter-spacing:-.01em;margin:8px 0 20px}
.wc-tasks{display:flex;flex-direction:column;gap:12px;text-align:left;margin-bottom:20px}
.wc-task{display:flex;gap:12px;align-items:flex-start}
.wc-ic{flex:none;width:30px;height:30px;border-radius:6px;display:grid;place-items:center;
  font-size:15px;background:rgba(255,255,255,.06);border:1px solid var(--line)}
.wc-ic.shard{color:var(--hit)}.wc-ic.ring{color:var(--perfect)}.wc-ic.gey{color:#8affd0}
.wc-task b{display:block;font:800 13px/1.3 system-ui;letter-spacing:.01em;margin-bottom:2px}
.wc-task span{font:500 12px/1.35 system-ui;color:var(--dim)}
.wc-controls{font:700 var(--micro)/1.4 system-ui;letter-spacing:.14em;color:var(--dim);
  text-transform:uppercase;margin-bottom:18px}
.wc-final{display:flex;justify-content:space-between;align-items:baseline;margin:18px 0;
  padding:14px 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
.wc-final span{font:800 var(--micro)/1 system-ui;letter-spacing:.2em;text-transform:uppercase;color:var(--dim)}
.wc-final b{font:900 32px/1 system-ui;font-variant-numeric:tabular-nums;color:var(--perfect)}
.wc-best{font:800 var(--micro)/1 system-ui;letter-spacing:.22em;color:var(--hit);margin-bottom:18px;min-height:1em}
.walk-card .primary{width:100%}

/* ---------- stage 5: orbital approach ---------- */
#orbitcv{position:absolute;inset:0;width:100%;height:100%;z-index:2;pointer-events:none}

.buildtag{margin-top:14px;font:800 9px/1 system-ui;letter-spacing:.3em;color:var(--dim);opacity:.55}

</style>
</head>
<body>
<div id="stage">
  <canvas id="view"></canvas>
  <canvas id="orbitcv" class="hidden"></canvas>
  <div id="grain"></div>
  <div id="vignette"></div>

  <!-- QTE prompt layer -->
  <div id="prompts"></div>
  <div id="floats"></div>

  <!-- HUD -->
  <div id="hud" class="hidden">
    <div class="hud-row top">
      <div class="hud-stage">
        <span class="lbl" id="hud-stage-lbl">Stage 1</span>
        <span class="val small" id="hud-stage-name">IGNITION</span>
      </div>
      <span id="hud-score" class="hidden"></span>
      <span id="hud-combo" class="hidden"><span id="hud-mult"></span></span>
    </div>
    <div class="hud-row mid">
      <div id="boss-bar" class="hidden">
        <div class="boss-name" id="boss-name">MAGPIE</div>
        <div class="boss-track"><div class="boss-fill" id="boss-fill"></div></div>
        <div class="boss-phase" id="boss-phase"></div>
      </div>
    </div>
    <div class="hud-dock">
      <div class="hull">
        <div class="lbl">Life <span id="life-count">4</span>/4</div>
        <div class="hull-track"><div class="hull-fill" id="hull-fill"></div></div>
      </div>
      <div class="scorebar">
        <div class="scorebar-label"><span>Progress</span><span id="scorebar-num">0 / 1000</span></div>
        <div class="progress"><div class="progress-fill" id="progress-fill"></div></div>
      </div>
    </div>
    <button id="mute" class="ghost-btn" aria-label="Toggle sound">SOUND ON</button>
  </div>

  <!-- Planetfall walk mode -->
