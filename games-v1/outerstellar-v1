      W.best = W.score;
      try { localStorage.setItem('outerstellar.walkbest', String(W.best)); } catch (e) {}
    }
  }
  function walkHud() {
    if (W.endgame && !W.endgameDone) {
      $('wq-shards').textContent = '\u25c6 ' + W.shards + '/' + surface.shardTotal;
      $('wq-rings').textContent = '\u2726 ' + W.relics + '/' + W.relicTotal;
    } else {
      $('wq-shards').textContent = '\u25c6 ' + W.shards + '/' + surface.shardTotal;
      $('wq-rings').textContent = '\u25ce ' + W.ringsHit + '/' + surface.ringTotal;
    }
    $('wq-score').textContent = W.score.toLocaleString();
  }

  // ----- objective flow: what the player should do right now -----
  function setObjective(label, text, flash) {
    $('wq-obj-label').textContent = label;
    $('wq-obj-text').textContent = text;
    if (flash) {
      const o = $('wq-objective');
      o.classList.remove('flash'); void o.offsetWidth; o.classList.add('flash');
    }
  }
  function refreshObjective() {
    const sLeft = surface.shardTotal - W.shards;
    const rLeft = surface.ringTotal - W.ringsHit;
    if (sLeft > 0) {
      setObjective('OBJECTIVE \u00b7 1 OF 2',
        'Collect star shards \u2014 ' + sLeft + ' left. Follow the light beams.');
    } else if (rLeft > 0) {
      setObjective('OBJECTIVE \u00b7 2 OF 2',
        'Clear the jump rings \u2014 ' + rLeft + ' left. Use geysers to reach the high ones.');
    } else if (W.endgame && !W.endgameDone) {
      const relLeft = W.relicTotal - W.relics;
      if (relLeft > 0) {
        setObjective('BONUS \u00b7 RELICS',
          'Recover ' + relLeft + ' alien relic' + (relLeft > 1 ? 's' : '') + ' scattered across the wilds.');
      } else if (!W.summitDone) {
        setObjective('BONUS \u00b7 SUMMIT',
          'Climb to the glowing monument at the highest peak.');
      }
    } else if (W.endgameDone) {
      setObjective('LEGEND', 'Everything found. This world is yours.');
    } else {
      setObjective('COMPLETE', 'Planet fully charted. Roam free.');
    }
  }
  const JOY_R = 46;   // knob travel in px

  function startWalk() {
    const firstTime = !W.introSeen;
    state = S.WALK;
    guard('walk-ui', () => {
      ['boot', 'hangar', 'intro', 'results', 'fail', 'tally', 'hud'].forEach((id) => $(id).classList.add('hidden'));
      $('walk-ui').classList.remove('hidden');
      $('walk-done').classList.add('hidden');
      $('walk-intro').classList.toggle('hidden', !firstTime);
    });
    guard('walk-env', () => {
      surface.group.visible = true;
      space.planet.visible = false;               // we're standing on it now
      space.group.visible = false;                // hide the space starfield behind our sky dome
      setWalkLights(true);
      renderer.toneMappingExposure = 1.28;
      if (scene.fog) {
        W.savedFog = { d: scene.fog.density };
        scene.fog.density = 0.0042;               // gentle depth haze matching the sky horizon
        if (scene.fog.color && scene.fog.color.setHex) scene.fog.color.setHex(0x2c5a48);
      }
    });
    guard('walk-quest', () => {
      surface.resetQuest();
      W.score = 0; W.shards = 0; W.ringsHit = 0; W.travel = 0;
      W.doneShards = false; W.doneRings = false;
      W.endgame = false; W.endgameDone = false; W.relics = 0; W.summitDone = false;
      W.paused = firstTime;                       // hold movement until briefing dismissed
      walkHud();
      refreshObjective();
      $('walk-banner').classList.add('hidden');
      $('walk-proximity').classList.add('hidden');
      $('compass').classList.add('hidden');
    });
    guard('walk-actors', () => {
      W.pos.set(0, surface.height(0, 4) , 4);
      W.vy = 0; W.heading = Math.PI; W.camYaw = Math.PI; W.cycle = 0;
      W.air = false; W.jumpSquash = 0; W.landRecover = 0; astroRoot.scale.setScalar(1);
      astroRoot.visible = true;
      astroRoot.scale.setScalar(1);
      // the rocket you rode in, parked at the landing site
      shipRoot.visible = true;
      shipRoot.scale.setScalar(1);
      shipRoot.rotation.set(0, 0.7, 0);
      const sx = 7, sz = -9;
      shipRoot.position.set(sx, surface.height(sx, sz) + (ship ? ship.length / 2 + 0.55 : 2.1), sz);
      W.shipCol = { x: sx, z: sz, r: 1.15 };
      if (ship) { ship.setThrottle(0); ship.setDamage(0); }
    });
    AUDIO.ui();
  }

  function exitWalk() {
    guard('walk-exit', () => {
      surface.group.visible = false;
      space.planet.visible = true;
      space.group.visible = true;
      setWalkLights(false);
      renderer.toneMappingExposure = 1.05;
      if (scene.fog && W.savedFog) {
        scene.fog.density = W.savedFog.d;
        if (scene.fog.color && scene.fog.color.setHex) scene.fog.color.setHex(0x03050a);
      }
      joyEnd();
      W.look.id = null;
      $('walk-ui').classList.add('hidden');
      $('boot').classList.remove('hidden');
      shipRoot.rotation.set(0, 0, 0);
      state = S.BOOT;
    });
  }

  // on-screen controls: left half = floating joystick (visible), right half = camera look drag
  const stageEl = $('stage');
  const joyBase = $('joy-base'), joyKnob = $('joy-knob');

  function joyShow(x, y) {
    joyBase.style.left = x + 'px';
    joyBase.style.top = y + 'px';
    joyKnob.style.transform = 'translate(0px,0px)';
    joyBase.classList.remove('hidden');
  }
  function joyMoveTo(dx, dy) {
    const m = Math.hypot(dx, dy);
    if (m > JOY_R) { dx *= JOY_R / m; dy *= JOY_R / m; }
    joyKnob.style.transform = 'translate(' + dx + 'px,' + dy + 'px)';
    W.joy.x = dx / JOY_R;
    W.joy.y = dy / JOY_R;
  }
  function joyEnd() {
    W.joy.id = null; W.joy.x = 0; W.joy.y = 0;
    joyBase.classList.add('hidden');
  }

  function doJump() {
    if (state === S.WALK && !W.air) {
      W.vy = 8.4;                 // stronger pop
      W.air = true;
      W.jumpSquash = -1;          // negative = stretch up on launch
      W.landRecover = 0;
      AUDIO.whoosh();
      FX.kick(0.12);
    }
  }

  stageEl.addEventListener('pointerdown', (e) => {
    if (state !== S.WALK || e.target.closest('button')) return;
    if (e.clientX < window.innerWidth * 0.55 && W.joy.id === null) {
      W.joy.id = e.pointerId;
      W.joy.ox = e.clientX; W.joy.oy = e.clientY;
      joyShow(e.clientX, e.clientY);
      joyMoveTo(0, 0);
    } else if (W.look.id === null) {
      W.look.id = e.pointerId;
      W.look.lx = e.clientX;
    }
  }, { passive: true });

  stageEl.addEventListener('pointermove', (e) => {
    if (state !== S.WALK) return;
    if (e.pointerId === W.joy.id) {
      joyMoveTo(e.clientX - W.joy.ox, e.clientY - W.joy.oy);
    } else if (e.pointerId === W.look.id) {
      W.camYaw -= (e.clientX - W.look.lx) * 0.007;
      W.look.lx = e.clientX;
    }
  }, { passive: true });

  const walkEnd = (e) => {
    if (e.pointerId === W.joy.id) joyEnd();
    if (e.pointerId === W.look.id) W.look.id = null;
  };
  stageEl.addEventListener('pointerup', walkEnd, { passive: true });
  stageEl.addEventListener('pointercancel', walkEnd, { passive: true });

  $('btn-jump').addEventListener('pointerdown', (e) => {
    e.stopPropagation();
    guard('jump', doJump);
  }, { passive: true });

  window.addEventListener('keydown', (e) => {
    if (state !== S.WALK || e.repeat) return;
    const k = e.code;
    if (k === 'KeyW' || k === 'ArrowUp') W.keys.y = -1;
    if (k === 'KeyS' || k === 'ArrowDown') W.keys.y = 1;
    if (k === 'KeyA' || k === 'ArrowLeft') W.keys.x = -1;
    if (k === 'KeyD' || k === 'ArrowRight') W.keys.x = 1;
    if (k === 'Space') doJump();
  });
  window.addEventListener('keyup', (e) => {
    if (state !== S.WALK) return;
    const k = e.code;
    if (k === 'KeyW' || k === 'ArrowUp' || k === 'KeyS' || k === 'ArrowDown') W.keys.y = 0;
    if (k === 'KeyA' || k === 'ArrowLeft' || k === 'KeyD' || k === 'ArrowRight') W.keys.x = 0;
  });

  function layoutWalk(dt) {
    surface.update(tGlobal);

    // paused (briefing open): keep the world alive but freeze the astronaut
    const jx = W.paused ? 0 : Math.max(-1, Math.min(1, W.joy.x + W.keys.x));
    const jy = W.paused ? 0 : Math.max(-1, Math.min(1, W.joy.y + W.keys.y));
    const mag = Math.min(1, Math.hypot(jx, jy));

    if (mag > 0.08) {
      const fwdX = Math.sin(W.camYaw), fwdZ = Math.cos(W.camYaw);    // screen-up = away from camera
      const rgtX = -Math.cos(W.camYaw), rgtZ = Math.sin(W.camYaw);   // screen-right
      let dx = fwdX * (-jy) + rgtX * jx;
      let dz = fwdZ * (-jy) + rgtZ * jx;
      const dl = Math.hypot(dx, dz) || 1;
      dx /= dl; dz /= dl;
      const speed = 6.2 * mag;
      W.pos.x += dx * speed * dt;
      W.pos.z += dz * speed * dt;
      // keep on the map
      const r = Math.hypot(W.pos.x, W.pos.z);
      if (r > surface.bound) { W.pos.x *= surface.bound / r; W.pos.z *= surface.bound / r; }
      // solid rocks: push out of any collider circle unless jumped above its top
      guard('collide', () => {
        for (const c of surface.colliders) {
          if (W.pos.y > c.top) continue;               // airborne above it — clears
          const ddx = W.pos.x - c.x, ddz = W.pos.z - c.z;
          const d2 = ddx * ddx + ddz * ddz;
          if (d2 < c.r * c.r && d2 > 0.0001) {
            const d = Math.sqrt(d2);
            W.pos.x = c.x + (ddx / d) * c.r;
            W.pos.z = c.z + (ddz / d) * c.r;
          }
        }
        // the parked rocket is solid too
        if (W.shipCol) {
          const c = W.shipCol;
          const ddx = W.pos.x - c.x, ddz = W.pos.z - c.z;
          const d2 = ddx * ddx + ddz * ddz;
          if (d2 < c.r * c.r && d2 > 0.0001) {
            const d = Math.sqrt(d2);
            W.pos.x = c.x + (ddx / d) * c.r;
            W.pos.z = c.z + (ddz / d) * c.r;
          }
        }
      });
      const target = Math.atan2(dx, dz);
      let dh = target - W.heading;
      while (dh > Math.PI) dh -= Math.PI * 2;
      while (dh < -Math.PI) dh += Math.PI * 2;
      W.heading += dh * Math.min(1, dt * 10);
      W.cycle += speed * dt * 1.6;
    } else {
      W.cycle += dt * 0.6;   // idle sway
    }

    // jump physics with weight: lighter on the way up + a hang at the apex,
    // heavier on the way down so the arc reads as real, not floaty.
    const groundY = surface.height(W.pos.x, W.pos.z);
    let g;
    if (W.vy > 3) g = 13;              // rising fast — light
    else if (W.vy > -3) g = 9;         // near apex — hang time
    else g = 22;                        // falling — snappy, weighty
    W.vy -= g * dt;
    W.pos.y += W.vy * dt;
    if (W.pos.y <= groundY) {
      const impact = -W.vy;
      W.pos.y = groundY;
      W.vy = 0;
      if (W.air) {                      // just landed
        W.landRecover = Math.min(1, impact / 9);   // squash amount from impact speed
        if (impact > 4) { FX.kick(0.18); AUDIO.mash(); }
        if (impact > 2) surface.print(W.pos.x, W.pos.z, W.heading);
      }
      W.air = false;
    }
    // ease squash/stretch springs back toward neutral
    W.jumpSquash = (W.jumpSquash || 0) * Math.pow(0.001, dt);
    W.landRecover = (W.landRecover || 0) * Math.pow(0.0002, dt);

    // footprints while grounded and moving
    if (!W.air && mag > 0.08) {
      W.travel += Math.hypot(jx, jy) * 6.2 * dt;
      if (W.travel > 0.42) {
        W.travel = 0;
        guard('print', () => surface.print(W.pos.x, W.pos.z, W.heading));
      }
    }

    // quest events
    guard('quest', () => {
      const ev = surface.quest(W.pos.x, W.pos.y, W.pos.z, W.air, dt, tGlobal);
      if (ev.shard) {
        W.shards++;
        walkScore(250);
        walkHud();
        refreshObjective();
        FX.burst(ev.shard, '#7fd6ff', 30, 5);
        AUDIO.perfect(W.shards);
        if (!W.doneShards && ev.shardsLeft === 0) {
          W.doneShards = true;
          walkScore(2000);
          surface.igniteAurora();
          walkBanner('CONSTELLATION COMPLETE\n+2000');
          setObjective('OBJECTIVE \u00b7 2 OF 2', 'Now clear the jump rings. Geysers launch you to the high ones.', true);
          AUDIO.fanfare(true);
          setTimeout(() => guard('aur-boom', () => AUDIO.boom()), 400);
          checkAllDone();
        } else if (ev.shardsLeft > 0) {
          walkBanner('+250');
        }
      }
      if (ev.ring) {
        W.ringsHit++;
        walkScore(400);
        walkHud();
        refreshObjective();
        FX.burst(ev.ring, '#ffd76b', 26, 4);
        AUDIO.hit(W.ringsHit + 3);
        if (!W.doneRings && ev.ringsLeft === 0) {
          W.doneRings = true;
          walkScore(1500);
          walkBanner('TRIAL MASTER\n+1500');
          AUDIO.fanfare(true);
          checkAllDone();
        } else if (ev.ringsLeft > 0) {
          walkBanner('+400');
        }
      }
      if (ev.geyser) {
        W.vy = 14; W.air = true; W.jumpSquash = -1; W.landRecover = 0;
        walkScore(50);
        FX.kick(0.35);
        AUDIO.whoosh();
        setTimeout(() => guard('gey2', () => AUDIO.whoosh()), 120);
      }
      if (ev.relic) {
        W.relics++;
        walkScore(600);
        walkHud();
        refreshObjective();
        FX.burst(ev.relic, '#ff8ad0', 34, 6);
        FX.flash(0.14, 90);
        AUDIO.perfect(W.relics + 4);
        if (ev.relicsLeft === 0) {
          walkScore(3000);
          walkBanner('ALL RELICS RECOVERED\n+3000');
          setObjective('BONUS \u00b7 SUMMIT', 'Now climb to the monument on the highest peak.', true);
          AUDIO.fanfare(true);
        } else {
          walkBanner('RELIC \u2726 +600');
        }
      }
      if (ev.summit) {
        W.summitDone = true;
        walkScore(5000);
        walkHud();
        FX.burst({ x: W.pos.x, y: W.pos.y + 2, z: W.pos.z }, '#ffe08a', 90, 12, 1.4);
        FX.flash(0.7, 500);
        FX.kick(1.0);
        walkBanner('SUMMIT REACHED\nWORLD MASTERED \u2014 +5000');
        AUDIO.fanfare(true);
        setTimeout(() => guard('sum-boom', () => AUDIO.boom()), 400);
        W.endgameDone = true;
        refreshObjective();
        checkFullClear();
      }
    });

    // astronaut pose (feet at legs' bottom ~= -1.0 local)
    astroRoot.position.set(W.pos.x, W.pos.y + 1.0, W.pos.z);
    astroRoot.rotation.set(0, W.heading, 0);
    if (astro) {
      if (W.air) {
        // in-flight tuck: legs bend up, arms out for balance, lean into velocity
        const rising = W.vy > 0;
        const tuck = rising ? 0.5 : 0.9;
        if (astro.legL) astro.legL.rotation.x = tuck;
        if (astro.legR) astro.legR.rotation.x = tuck * 0.7;
        astro.armL.rotation.x = rising ? -1.1 : -0.4;
        astro.armR.rotation.x = rising ? -1.1 : -0.4;
        astro.armL.rotation.z = 0.6; astro.armR.rotation.z = -0.6;
      } else {
        const sw = mag > 0.08 ? Math.sin(W.cycle * 4.4) * 0.62 : Math.sin(W.cycle * 2) * 0.05;
        if (astro.legL) astro.legL.rotation.x = sw;
        if (astro.legR) astro.legR.rotation.x = -sw;
        astro.armL.rotation.x = -sw * 0.8;
        astro.armR.rotation.x = sw * 0.8;
        astro.armL.rotation.z = 0.34; astro.armR.rotation.z = -0.34;
        astroRoot.position.y += Math.abs(Math.sin(W.cycle * 4.4)) * 0.06 * mag;
      }
      // squash & stretch: stretch on launch/rise, squash on landing
      const stretch = W.air ? (W.vy > 0 ? 0.14 : 0.06) : 0;
      const squash = (W.landRecover || 0) * 0.4;
      const sy = 1 + stretch - squash;
      const sxz = 1 - stretch * 0.6 + squash * 0.5;
      astroRoot.scale.set(sxz, Math.max(0.4, sy), sxz);
    }

    // chase camera
    if (W.look.id === null) {   // auto-follow only when not manually looking
      let dy2 = W.heading - W.camYaw;
      while (dy2 > Math.PI) dy2 -= Math.PI * 2;
      while (dy2 < -Math.PI) dy2 += Math.PI * 2;
      W.camYaw += dy2 * Math.min(1, dt * (mag > 0.08 ? 0.55 : 0));
    }
    const back = 6.4, up = 2.8;
    const cx = W.pos.x - Math.sin(W.camYaw) * back;
    const cz = W.pos.z - Math.cos(W.camYaw) * back;
    const cy = Math.max(surface.height(cx, cz) + 1.2, W.pos.y + up);
    camera.position.x += (cx - camera.position.x) * Math.min(1, dt * 5);
    camera.position.y += (cy - camera.position.y) * Math.min(1, dt * 5);
    camera.position.z += (cz - camera.position.z) * Math.min(1, dt * 5);
    camera.lookAt(W.pos.x, W.pos.y + 1.5, W.pos.z);

    // ----- directional pointer to nearest objective -----
    guard('compass', () => {
      const comp = $('compass');
      const goal = surface.nearestGoal(W.pos.x, W.pos.z);
      if (!goal || W.paused) { comp.classList.add('hidden'); }
      else {
        comp.classList.remove('hidden');
        // world bearing relative to where the camera faces
        const bearing = Math.atan2(goal.x - W.pos.x, goal.z - W.pos.z);
        const rel = bearing - W.camYaw;
        // place the arrow on a ring around screen center, rotate it to point outward
        const R = Math.min(window.innerWidth, window.innerHeight) * 0.28;
        const sx = Math.sin(rel) * R, sy = -Math.cos(rel) * R;
        comp.style.transform = 'translate(calc(-50% + ' + sx.toFixed(0) + 'px), calc(-50% + ' + sy.toFixed(0) + 'px)) rotate(' + rel.toFixed(3) + 'rad)';
        const distEl = $('compass-dist');
        distEl.textContent = Math.round(goal.dist) + 'm';
        distEl.style.transform = 'rotate(' + (-rel).toFixed(3) + 'rad)';   // keep text upright
        comp.style.color = goal.kind === 'ring' ? 'var(--perfect)'
          : goal.kind === 'relic' ? '#ff8ad0'
          : goal.kind === 'summit' ? '#ffe08a'
          : 'var(--hit)';
      }
    });

    // ----- proximity hint: near a geyser you haven't used -----
    guard('proximity', () => {
      const prox = $('walk-proximity');
      const gy = surface.nearestGeyser(W.pos.x, W.pos.z);
      const ringsLeft = surface.ringTotal - W.ringsHit;
      if (!W.paused && gy && gy.dist < 5 && !W.air && ringsLeft > 0) {
        prox.textContent = 'Step on the vent to launch \u2191';
        prox.classList.remove('hidden');
      } else if (!W.paused && W.air && ringsLeft > 0) {
        prox.textContent = 'Steer with the stick \u2014 aim for a ring';
        prox.classList.remove('hidden');
      } else {
        prox.classList.add('hidden');
      }
    });
  }

  function checkAllDone() {
    if (W.doneShards && W.doneRings && !W.endgame) {
      W.endgame = true;
      guard('unlock-endgame', () => {
        const info = surface.unlockEndgame();
        W.relicTotal = info.relicTotal;
        W.relics = 0;
      });
      walkHud();
      setTimeout(() => guard('endgame-reveal', () => {
        walkBanner('WILDS UNLOCKED\nRelics + a summit await');
        setObjective('BONUS \u00b7 RELICS', 'Recover ' + W.relicTotal + ' alien relics scattered across the wilds.', true);
        AUDIO.fanfare(true);
      }), 1800);
    }
  }

  function checkFullClear() {
    setTimeout(() => guard('walk-complete', () => {
      $('wd-score').textContent = '0';
      FX.countUp($('wd-score'), W.score, 900);
      const isBest = W.score >= W.best;
      $('wd-best').textContent = isBest ? 'NEW EXPLORATION BEST' : 'Best \u00b7 ' + W.best.toLocaleString();
      $('walk-done').querySelector('.wc-title').textContent = 'WORLD MASTERED';
      $('walk-done').classList.remove('hidden');
    }), 1800);
  }

  // ---------- input ----------
  INPUT.attach($('stage'));
  INPUT.on((kind, data) => {
    if (state !== S.PLAY) return;
    guard('input', () => {
      const st = LEVELS.STAGES[stageIdx];
      if (st && st.kind === 'orbit') {
        if (kind === 'down') orbitGame && orbitGame.tap();
        return;
      }
      qte.handle(kind, data);
    });
  });

  // ---------- buttons ----------
  $('btn-start').onclick = () => guard('btn', () => {
    if (state !== S.BOOT) return;
    AUDIO.unlock(); AUDIO.ui();
    $('boot').classList.add('hidden');
    $('hangar').classList.remove('hidden');
    state = S.HANGAR;
  });
  guard('customizer', () => CUSTOMIZER.mount(cfg, (key) => {
    if (key === 'body' || key === 'ship' || key === 'flame') rebuildShip();
    else if (key === 'suit' || key === 'visor' || key === 'acc') rebuildAstro();
  }));
  $('btn-launch').onclick = () => guard('btn', () => {
    if (state !== S.HANGAR) return;
    AUDIO.ui();
    $('hangar').classList.add('hidden');
    stageIdx = 0; results.length = 0; runScore = 0;
    hull = CFG.hull.max;                 // full life at the start of a run
    showIntro();
  });
  $('btn-next').onclick = () => guard('btn', () => { if (state !== S.RESULTS) return; AUDIO.ui(); nextStage(); });
  $('btn-retry').onclick = () => guard('btn', () => { if (state !== S.RESULTS) return; AUDIO.ui(); startStage(); });
  // life hit 0 → restart the WHOLE run from stage 1 with full life
  $('btn-fail-retry').onclick = () => guard('btn', () => {
    if (state !== S.FAIL) return;
    AUDIO.ui();
    stageIdx = 0; results.length = 0; runScore = 0;
    hull = CFG.hull.max;
    showIntro();
  });
  $('btn-again').onclick = () => guard('btn', () => {
    if (state !== S.TALLY) return;
    AUDIO.ui();
    $('tally').classList.add('hidden');
    $('hangar').classList.remove('hidden');
    state = S.HANGAR;
  });
  $('mute').onclick = (e) => guard('btn', () => {
    const m = AUDIO.toggle();
    e.target.textContent = m ? 'SOUND OFF' : 'SOUND ON';
  });
  $('intro').addEventListener('pointerdown', () =>
    guard('intro-skip', () => { if (state === S.INTRO) startStage(); }));
  $('btn-explore').onclick = () => guard('btn', () => { AUDIO.unlock(); startWalk(); });
  $('btn-walk').onclick = () => guard('btn', () => startWalk());
  $('btn-exit-walk').onclick = () => guard('btn', () => exitWalk());
  $('btn-walk-go').onclick = () => guard('btn', () => {
    AUDIO.ui();
    W.introSeen = true; W.paused = false;
    $('walk-intro').classList.add('hidden');
  });
  $('btn-walk-stay').onclick = () => guard('btn', () => {
    AUDIO.ui();
    $('walk-done').classList.add('hidden');
  });

  // ---------- per-state layouts ----------
  function layoutHangar(dt) {
    turntable += dt * 0.4;
    shipRoot.visible = true; astroRoot.visible = true;
    shipRoot.position.set(3.2, -0.4, 0);
    shipRoot.rotation.set(0.12, turntable, 0.18);
    shipRoot.scale.setScalar(1.05);
    astroRoot.position.set(0.9, -0.5, 3.2);
    astroRoot.rotation.set(0, Math.sin(turntable * 0.7) * 0.5, 0);
    astroRoot.scale.setScalar(1.15);
    if (astro) astro.wave(tGlobal);
    camera.position.set(0.6, 0.6, 8.2);
    camera.lookAt(1.9, -0.2, 0.6);
  }

  function layoutPlay(dt) {
    astroRoot.visible = false;
    shipRoot.visible = true;
    shipRoot.position.set(0, -1.5 + Math.sin(tGlobal * 0.9) * 0.1, 2.2);
    shipRoot.rotation.x = Math.PI * 0.5 + 0.12 + Math.sin(tGlobal * 0.6) * 0.04;
    shipRoot.rotation.z = Math.sin(tGlobal * 0.7) * 0.12;
    shipRoot.rotation.y = 0;
    shipRoot.scale.setScalar(0.62);
    if (ship) ship.setThrottle(0.65 + Math.sin(tGlobal * 6) * 0.08 + Math.min(0.3, qte.combo * 0.02));

    if (bossModel) {
      const b = bossModel;
      b.obj.position.y = 0.6 + Math.sin(tGlobal * 0.8) * 0.35;
      b.obj.position.x = Math.sin(tGlobal * 0.45) * 2.2;
      b.obj.rotation.y += dt * 0.3;
      if (b.ring) b.ring.rotation.z += dt * 0.9;
      if (b.claws) b.claws.forEach((c, i) => { c.rotation.x = Math.sin(tGlobal * 1.6 + i) * 0.3; });
      if (b.panels) b.panels.forEach((p, i) => { p.rotation.x = Math.sin(tGlobal * 0.6 + i) * 0.2; });
      const danger = bossCtl && bossCtl.mode === 'defend';
      if (b.pupil) b.pupil.material.emissiveIntensity = danger ? 2.4 + Math.sin(tGlobal * 18) * 1.2 : 1.2;
      if (b.lens) b.lens.material.emissiveIntensity = danger ? 2.6 + Math.sin(tGlobal * 20) * 1.4 : 1.0;
    }
  }

  function layoutTally() {
    astroRoot.visible = true;
    shipRoot.visible = false;
    astroRoot.position.set(0, -0.6, 4.5);
    astroRoot.rotation.y = Math.sin(tGlobal * 0.5) * 0.4;
    if (astro) astro.wave(tGlobal);
    camera.position.set(0, 0.4, 9);
    camera.lookAt(0, -0.2, 0);
  }

  // ---------- main loop ----------
  let last = performance.now();
  function loop(now) {
    requestAnimationFrame(loop);
    guard('tick', () => tick(now));
  }
  function tick(now) {
    let dt = Math.min(0.05, (now - last) / 1000);
    last = now;
    tGlobal += dt;

    guard('space', () => {
      space.update(dt, tGlobal);
      const prog = (stageIdx + (state === S.PLAY ? 0.5 : 0)) / LEVELS.STAGES.length;
      space.approach(state >= S.INTRO ? prog : 0);
    });

    if (state === S.BOOT || state === S.HANGAR) {
      guard('hangar', () => layoutHangar(dt));
    } else if (state === S.PLAY) {
      playT += dt;
      guard('layout', () => layoutPlay(dt));
      guard('qte', () => { if (!FX.frozen) qte.update(dt); });

      // self-heal: a run stage with a dead engine re-arms itself
      if (!bossCtl && qte.tally.total === 0 && playT - healT > 1) {
        healT = playT;
        guard('re-arm', () => armStage(LEVELS.STAGES[stageIdx]));
      }

      guard('stage', () => {
        const stg = LEVELS.STAGES[stageIdx];
        if (stg && stg.kind === 'orbit') {
          shipRoot.visible = false;              // the dot IS the ship now
          if (orbitGame) {
            orbitGame.update(dt);
            orbitGame.render();
          }
          return;
        }
        if (bossCtl) {
          const add = bossCtl.update(dt, qte.clock);
          if (add) qte.push(add);
          // boss: score fills toward 1000 as HP drops
          stageScore = Math.round((1 - bossCtl.hp / bossCtl.maxHp) * CFG.score.goal);
          updateScoreBar();
          // clear is triggered by the boss's own onDeath hook (with its FX delay)
        } else {
          // run stage: clears the instant score reaches the 1000 goal
          if (stageScore >= CFG.score.goal) endStage(true);
          else if (qte.finished()) endStage(false);   // ran out of beats short of goal
        }
      });
    } else if (state === S.WALK) {
      guard('walk', () => layoutWalk(dt));
    } else if (state === S.TALLY) {
      guard('tally', () => layoutTally());
    } else {
      if (ship) ship.setThrottle(0.35);
      guard('idle', () => layoutPlay(dt));
    }

    guard('ship', () => { if (ship) ship.update(dt); });
    guard('fx', () => FX.update(dt));
    guard('render', () => renderer.render(scene, camera));
  }
  requestAnimationFrame(loop);
})();

</script>
</body>
</html>
