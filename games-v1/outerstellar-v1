/* Bosses: MAGPIE (salvage drone) and WARDEN (guardian satellite).
   Loop: telegraph → DEFEND beat → window → ATTACK volley. */
const BOSS = (() => {
  const DIRS = ['up', 'down', 'left', 'right'];

  function makeMagpie() {
    const g = new THREE.Group();
    const body = new THREE.MeshStandardMaterial({ color: '#5b6270', metalness: .85, roughness: .38 });
    const rust = new THREE.MeshStandardMaterial({ color: '#7c4a2d', metalness: .6, roughness: .7 });
    const eye = new THREE.MeshStandardMaterial({ color: '#ff8a5c', emissive: '#ff5f2c', emissiveIntensity: 1.2, roughness: .3 });

    const core = new THREE.Mesh(new THREE.IcosahedronGeometry(1.5, 1), body);
    core.castShadow = true;
    g.add(core);

    const ring = new THREE.Mesh(new THREE.TorusGeometry(2.3, 0.16, 10, 40), rust);
    ring.rotation.x = 1.1;
    g.add(ring);

    const lens = new THREE.Mesh(new THREE.SphereGeometry(0.5, 20, 16), eye);
    lens.position.z = 1.4;
    g.add(lens);

    const claws = [];
    for (let i = 0; i < 4; i++) {
      const a = (i / 4) * Math.PI * 2;
      const arm = new THREE.Group();
      const s1 = new THREE.Mesh(new THREE.BoxGeometry(0.18, 1.3, 0.18), rust);
      s1.position.y = -0.65;
      const s2 = new THREE.Mesh(new THREE.BoxGeometry(0.15, 0.9, 0.15), body);
      s2.position.set(0, -1.65, 0.28);
      s2.rotation.x = -0.5;
      arm.add(s1, s2);
      arm.position.set(Math.cos(a) * 1.2, 0, Math.sin(a) * 1.2);
      arm.rotation.z = Math.cos(a) * 0.4;
      arm.rotation.x = Math.sin(a) * 0.4;
      arm.traverse(o => { if (o.isMesh) o.castShadow = true; });
      g.add(arm);
      claws.push(arm);
    }
    return { obj: g, ring, lens, claws, core };
  }

  function makeWarden() {
    const g = new THREE.Group();
    const hull = new THREE.MeshStandardMaterial({ color: '#c9cfd8', metalness: .9, roughness: .28 });
    const dark = new THREE.MeshStandardMaterial({ color: '#191d24', metalness: .8, roughness: .5 });
    const glow = new THREE.MeshStandardMaterial({ color: '#7fd6ff', emissive: '#3aa5e0', emissiveIntensity: 1.4, roughness: .2 });

    const core = new THREE.Mesh(new THREE.CylinderGeometry(1.5, 1.5, 2.6, 8), hull);
    core.castShadow = true;
    core.rotation.x = Math.PI / 2;
    g.add(core);

    const cap = new THREE.Mesh(new THREE.SphereGeometry(1.6, 24, 18), dark);
    cap.position.z = 1.5; cap.scale.z = 0.6;
    g.add(cap);

    const eye = new THREE.Mesh(new THREE.TorusGeometry(0.85, 0.22, 12, 32), glow);
    eye.position.z = 1.85;
    g.add(eye);
    const pupil = new THREE.Mesh(new THREE.SphereGeometry(0.42, 20, 16), glow);
    pupil.position.z = 1.9;
    g.add(pupil);

    const panels = [];
    for (let i = 0; i < 2; i++) {
      const s = i ? 1 : -1;
      const arm = new THREE.Mesh(new THREE.BoxGeometry(2.4, 0.12, 1.5), dark);
      arm.position.set(s * 3.1, 0, 0);
      arm.castShadow = true;
      g.add(arm);
      panels.push(arm);
      const strut = new THREE.Mesh(new THREE.CylinderGeometry(0.1, 0.1, 1.6, 10), hull);
      strut.rotation.z = Math.PI / 2;
      strut.position.set(s * 1.9, 0, 0);
      g.add(strut);
    }

    const ring = new THREE.Mesh(new THREE.TorusGeometry(2.6, 0.1, 8, 48), hull);
    g.add(ring);

    return { obj: g, eye, pupil, panels, ring, core };
  }

  /* Fight controller. Feeds beats into the QTE engine one exchange at a time. */
  function fight(kind, qte, hooks) {
    const spec = CFG.boss[kind];
    const phases = kind === 'warden' ? spec.hp.slice() : [spec.hp];
    let phase = 0;
    let hp = phases[0];
    const maxHp = phases.reduce((a, b) => a + b, 0);
    let hpLeft = maxHp;
    let mode = 'idle';     // idle | defend | attack | dead
    let queue = [];
    let t = 0, nextAt = 900;
    let seed = 1;
    const rnd = () => ((seed = (seed * 1103515245 + 12345) & 0x7fffffff) / 0x7fffffff);

    function telegraph() {
      const k = 1 - (hpLeft / maxHp);
      return spec.telegraphStart + (spec.telegraphEnd - spec.telegraphStart) * k;
    }

    function pushDefend(now) {
      const tg = telegraph();
      const type = rnd() < 0.5 ? 'swipe' : 'tap';
      const b = {
        t: now + tg, type,
        label: 'DEFEND', danger: true, defend: true, lead: tg
      };
      if (type === 'swipe') b.dir = DIRS[Math.floor(rnd() * 4)];
      queue = [b];
      mode = 'defend';
      hooks.onTelegraph && hooks.onTelegraph(tg);
      AUDIO.droneOn();
      return [b];
    }

    function pushAttack(now) {
      const n = spec.volley;
      const arr = [];
      for (let i = 0; i < n; i++) {
        arr.push({
          t: now + 500 + i * 480, type: 'tap',
          label: 'HIT', attack: true, slot: i % 5, lead: 700
        });
      }
      queue = arr;
      mode = 'attack';
      AUDIO.droneOff();
      hooks.onAttackWindow && hooks.onAttackWindow();
      return arr;
    }

    return {
      get mode() { return mode; },
      get hp() { return hpLeft; },
      get maxHp() { return maxHp; },
      get phase() { return phase + 1; },
      get phases() { return phases.length; },
      get dead() { return mode === 'dead'; },

      // called when the QTE engine resolves a beat that belongs to the boss
      onResolve(kindRes, beat) {
        if (beat.attack && kindRes !== 'miss') {
          const dmg = kindRes === 'perfect' ? 2 : 1;
          hp -= dmg; hpLeft = Math.max(0, hpLeft - dmg);
          hooks.onDamage && hooks.onDamage(dmg, hpLeft / maxHp);
          AUDIO.bossHit();
          if (hp <= 0) {
            phase++;
            if (phase >= phases.length) {
              mode = 'dead';
              AUDIO.droneOff();
              AUDIO.boom();
              hooks.onDeath && hooks.onDeath();
              return;
            }
            hp = phases[phase];
            hooks.onPhase && hooks.onPhase(phase + 1);
            AUDIO.fanfare(true);
          }
        }
        if (beat.defend && kindRes === 'miss') {
          hooks.onPlayerHit && hooks.onPlayerHit();
        }
      },

      // drives the exchange loop; returns beats to inject (or null)
      update(dt, now) {
        if (mode === 'dead') return null;
        t += dt * 1000;
        if (queue.length && queue.every(b => b.done)) {
          queue = [];
          nextAt = now + 420;
          mode = 'idle';
        }
        if (mode === 'idle' && now >= nextAt) {
          return (rnd() < 0.5) ? pushDefend(now) : pushAttack(now);
        }
        return null;
      },
      makeModel() { return kind === 'magpie' ? makeMagpie() : makeWarden(); }
    };
  }

  return { fight, makeMagpie, makeWarden };
})();

/* ===== src/customizer.js ===== */
/* Hangar: turntable preview + swatch UI + localStorage (guarded for sandboxed preview). */
const CUSTOMIZER = (() => {
  const KEY = 'outerstellar.cfg';

  function load() {
    try {
      const raw = localStorage.getItem(KEY);
      if (raw) return Object.assign({}, CFG.defaults, JSON.parse(raw));
    } catch (e) { /* sandboxed: degrade silently */ }
    return Object.assign({}, CFG.defaults);
  }
  function save(cfg) {
    try { localStorage.setItem(KEY, JSON.stringify(cfg)); } catch (e) { /* no-op */ }
  }

  function mount(cfg, onChange) {
    const el = (id) => document.getElementById(id);

    function swatches(host, colors, key) {
      host.innerHTML = '';
      colors.forEach((c, i) => {
        const b = document.createElement('button');
        b.className = 'sw' + (cfg[key] === i ? ' on' : '');
        b.style.background = c;
        b.setAttribute('aria-label', key + ' ' + (i + 1));
        b.onclick = () => {
          cfg[key] = i;
          [...host.children].forEach((x, j) => x.classList.toggle('on', j === i));
          AUDIO.ui(); save(cfg); onChange(key);
        };
        host.appendChild(b);
      });
    }

    function chips(host, names, key) {
      host.innerHTML = '';
      names.forEach((n, i) => {
        const b = document.createElement('button');
        b.className = 'chip' + (cfg[key] === i ? ' on' : '');
        b.textContent = n;
        b.onclick = () => {
          cfg[key] = i;
          [...host.children].forEach((x, j) => x.classList.toggle('on', j === i));
          AUDIO.ui(); save(cfg); onChange(key);
        };
        host.appendChild(b);
      });
    }

    swatches(el('sw-suit'), CFG.palettes.suit, 'suit');
    swatches(el('sw-visor'), CFG.palettes.visor, 'visor');
    chips(el('sw-acc'), CFG.accessories, 'acc');
    chips(el('sw-body'), CFG.bodies, 'body');
    swatches(el('sw-ship'), CFG.palettes.ship, 'ship');
    swatches(el('sw-flame'), CFG.palettes.flame, 'flame');

    const tabs = [...document.querySelectorAll('.tab')];
    tabs.forEach(t => {
      t.onclick = () => {
        tabs.forEach(x => x.classList.toggle('active', x === t));
        el('tab-astro').classList.toggle('hidden', t.dataset.tab !== 'astro');
        el('tab-ship').classList.toggle('hidden', t.dataset.tab !== 'ship');
        AUDIO.ui();
        onChange('tab:' + t.dataset.tab);
      };
    });
  }

  return { load, save, mount };
})();

/* ===== src/game.js ===== */
/* OUTERSTELLAR main. Design rules:
   1. No DOM access can throw — $() always returns an element.
   2. Every entry point and subsystem runs guarded; failures log and skip, never stop play.
   3. A stage ARMS its QTE beats before anything cosmetic happens, and self-heals if dead. */
(() => {
  // ---------- throw-proof DOM ----------
  const NULL_EL = (() => {
    const e = document.createElement('div');
    return e;
  })();
  const $ = (id) => document.getElementById(id) || NULL_EL;

  function guard(label, fn) {
    try { return fn(); } catch (err) {
      if (!guard.seen) guard.seen = {};
      if (!guard.seen[label]) {
        guard.seen[label] = 1;
        try { console.error('outerstellar[' + label + ']', err); } catch (e) {}
      }
    }
  }

  // ---------- renderer ----------
  const canvas = $('view');
  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, powerPreference: 'high-performance' });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, CFG.render.pixelRatio));
  renderer.shadowMap.enabled = true;
  renderer.shadowMap.type = THREE.PCFSoftShadowMap;
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1.05;
  renderer.setClearColor(0x000000, 1);

  const scene = new THREE.Scene();
  scene.fog = new THREE.FogExp2(0x03050a, CFG.render.fog);
  const camera = new THREE.PerspectiveCamera(52, 16 / 9, 0.1, 2000);
  camera.position.set(0, 1.2, 8.5);

  function resize() {
    guard('resize', () => {
      const w = Math.min(CFG.render.maxW, window.innerWidth);
      const h = Math.min(CFG.render.maxH, window.innerHeight);
      renderer.setSize(w, h, false);
      canvas.style.width = '100%';
      canvas.style.height = '100%';
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
    });
  }
  window.addEventListener('resize', resize);
  resize();

  FX.init(scene, camera);
  const space = SPACE.build(scene);
  const surface = WALK.build(scene);

  // stage 5 orbital-approach minigame (2D canvas over the 3D starfield)
  let orbitGame = null;
  function orbitOn() {
    $('orbitcv').classList.remove('hidden');
    if (!orbitGame) {
      orbitGame = ORBIT.create($('orbitcv'), {
        onCapture: (isPerf, hops, streak, px) => guard('orbit-score', () => {
          const share = CFG.score.goal / 10;
          const gain = Math.round(isPerf ? share * (1 + CFG.score.perfectBonus) : share);
          stageScore = Math.min(CFG.score.goal, stageScore + gain);
          updateScoreBar();
          FX.float(px.x, px.y - 18, '+' + gain + (isPerf ? ' PERFECT' : ''), isPerf ? 'perfect' : 'hit');
        }),
        onDone: () => guard('orbit-done', () => { if (state === S.PLAY) endStage(true); }),
        onDead: () => guard('orbit-dead', () => {
          // a crash costs a life, not the run; only 0 life ends it
          if (state !== S.PLAY) return;
          loseLife();
          if (hull > 0 && orbitGame) orbitGame.start();   // respawn on the approach
        })
      });
    }
    orbitGame.start();
  }
  function orbitOff() {
    if (orbitGame) orbitGame.stop();
    $('orbitcv').classList.add('hidden');
  }

  // dedicated surface lighting rig — warm low sun + cool sky fill + ground bounce
  const walkSun = new THREE.DirectionalLight(0xffe4c0, 0.0);
  walkSun.position.set(-40, 34, -30);
  walkSun.castShadow = true;
  walkSun.shadow.mapSize.set(1024, 1024);
  walkSun.shadow.camera.near = 1;
  walkSun.shadow.camera.far = 140;
  walkSun.shadow.camera.left = -60;
  walkSun.shadow.camera.right = 60;
  walkSun.shadow.camera.top = 60;
  walkSun.shadow.camera.bottom = -60;
  walkSun.shadow.bias = -0.0006;
  scene.add(walkSun);
  const walkSky = new THREE.HemisphereLight(0x9fd4c8, 0x1a2b26, 0.0);   // sky / ground bounce
  scene.add(walkSky);
  const walkRim = new THREE.DirectionalLight(0x6fa8ff, 0.0);
  walkRim.position.set(30, 8, 40);
  scene.add(walkRim);
  function setWalkLights(on) {
    walkSun.intensity = on ? 2.9 : 0;
    walkSky.intensity = on ? 1.25 : 0;
    walkRim.intensity = on ? 0.65 : 0;
  }

  // ---------- actors ----------
  let cfg = CUSTOMIZER.load();
  let ship = null, astro = null, bossModel = null, bossCtl = null;
  const shipRoot = new THREE.Group();
  const astroRoot = new THREE.Group();
  const bossRoot = new THREE.Group();
  scene.add(shipRoot, astroRoot, bossRoot);

  function clear(root) {
    while (root.children.length) {
      const c = root.children.pop();
      c.traverse((o) => {
        if (o.geometry && o.geometry.dispose) o.geometry.dispose();
        if (o.material) {
          const m = Array.isArray(o.material) ? o.material : [o.material];
          m.forEach((x) => { if (x.map && x.map.dispose) x.map.dispose(); if (x.dispose) x.dispose(); });
        }
      });
    }
  }
  function rebuildShip() {
    guard('ship-build', () => {
      clear(shipRoot);
      ship = SHIP.build(cfg);
      shipRoot.add(ship.obj);
    });
  }
  function rebuildAstro() {
    guard('astro-build', () => {
      clear(astroRoot);
      astro = ASTRO.build(cfg);
      astroRoot.add(astro.obj);
    });
  }
  rebuildShip(); rebuildAstro();

  // ---------- QTE anchoring ----------
  const v = new THREE.Vector3();
  function project(worldVec) {
    v.copy(worldVec).project(camera);
    return {
      x: (v.x * 0.5 + 0.5) * window.innerWidth,
      y: (-v.y * 0.5 + 0.5) * window.innerHeight
    };
  }
  const SLOTS = [
    new THREE.Vector3(-2.2, 1.2, 1.0),
    new THREE.Vector3(2.2, 1.0, 1.0),
    new THREE.Vector3(0, 2.0, 0.4),
    new THREE.Vector3(-1.7, -0.9, 1.2),
    new THREE.Vector3(1.7, -1.0, 1.2)
  ];
  const slotTarget = (i) => SLOTS[((i | 0) % SLOTS.length + SLOTS.length) % SLOTS.length];

  // ---------- state ----------
  const S = { BOOT: 0, HANGAR: 1, INTRO: 2, PLAY: 3, RESULTS: 4, FAIL: 5, TALLY: 6, WALK: 7 };
  let state = S.BOOT;
  let stageIdx = 0;
  let stageScore = 0, runScore = 0, hull = CFG.hull.max, stageActions = 5;
  let sessionBest = 0;
  try { sessionBest = parseInt(localStorage.getItem('outerstellar.best') || '0', 10) || 0; } catch (e) {}
  const results = [];
  let turntable = 0, tGlobal = 0, playT = 0, healT = 0;

  const qte = QTE.create({
    camera, project,
    defaultTarget: () => SLOTS[0],
    onEvent: (kind, beat, meta) => guard('score', () => onBeat(kind, beat, meta))
  });
  qte.push = (list) => {
    list.forEach((b) => { b.target = slotTarget(b.slot != null ? b.slot : Math.floor(Math.random() * 5)); });
    qte.appendBeats(list);
  };

  // ---------- scoring ----------
  function onBeat(kind, beat, meta) {
    const s = CFG.score;
    let gain = 0;
    if (kind === 'miss') {
      loseLife();
      gain = 0;
    } else {
      const share = CFG.score.goal / stageActions;      // points per action
      gain = Math.round(kind === 'perfect' ? share * (1 + CFG.score.perfectBonus) : share);
    }
    stageScore = Math.max(0, stageScore + gain);
    updateScoreBar();

    const p = beat.px || project(SLOTS[0]);
    FX.float(p.x, p.y - 30, (gain > 0 ? '+' + gain : 'MISS'),
      kind === 'perfect' ? 'perfect' : kind === 'hit' ? 'hit' : 'miss');
    if (kind !== 'miss') {
      FX.burst(beat.target || SLOTS[0],
        kind === 'perfect' ? '#ffd76b' : '#7fd6ff',
        kind === 'perfect' ? 34 : 20);
    }
    if (bossCtl) bossCtl.onResolve(kind, beat);
  }

  // ---- life (out of 4, persists across stages) ----
  function loseLife() {
    hull = Math.max(0, hull - 1);
    updateHull();
    if (ship) ship.setDamage(1 - hull / CFG.hull.max);
    FX.kick(0.4); FX.flash(0.18, 130);
    if (hull <= 0 && state === S.PLAY) gameOver();
  }
  function updateHull() {
    const k = hull / CFG.hull.max;
    const f = $('hull-fill');
    f.style.width = (k * 100) + '%';
    f.classList.toggle('low', hull <= 1);
    $('life-count').textContent = hull;
  }

  // ---- score bar: fills toward the 1000 goal, wired to the number ----
  function updateScoreBar() {
    const shown = Math.min(stageScore, CFG.score.goal);
    $('hud-score').textContent = stageScore.toLocaleString();
    $('hud-mult').textContent = shown.toLocaleString();
    $('scorebar-num').textContent = shown.toLocaleString() + ' / ' + CFG.score.goal;
    const pct = Math.min(100, (stageScore / CFG.score.goal) * 100);
    $('progress-fill').style.width = pct + '%';
    $('progress-fill').classList.toggle('full', stageScore >= CFG.score.goal);
  }

  // ---- game over: life hit 0 → restart the whole run ----
  function gameOver() {
    if (state !== S.PLAY) return;
    qte.stop(); AUDIO.droneOff();
    if (typeof orbitOff === 'function') orbitOff();
    state = S.FAIL;
    $('hud').classList.add('hidden');
    $('fail').classList.remove('hidden');
    AUDIO.fanfare(false);
  }

  // ---------- stage flow ----------
  function showIntro() {
    state = S.INTRO;
    const st = LEVELS.STAGES[stageIdx];
    $('intro-num').textContent = 'Stage ' + st.n + (st.kind === 'boss' ? ' \u00b7 Boss' : '');
    $('intro-name').textContent = st.name;
    $('intro-radio').textContent = st.radio;
    $('intro').classList.remove('hidden');
    $('hud').classList.add('hidden');
    setTimeout(() => guard('intro-timer', () => { if (state === S.INTRO) startStage(); }), 2600);
  }

  // The only thing a stage strictly needs: beats in the engine.
  function armStage(st) {
    if (st.kind === 'boss' || st.kind === 'orbit') { qte.reset([]); return; }   // boss/orbit own their beats
    const beats = st.beats().map((b) => Object.assign(b, { target: slotTarget(b.slot || 0) }));
    qte.reset(beats);
  }

  // how many scoring actions a stage needs (to divide the 1000-point goal)
  function actionsFor(st) {
    if (st.kind === 'orbit') return 10;
    if (st.kind === 'boss') return CFG.boss[st.boss].hp.reduce ? CFG.boss[st.boss].hp.reduce((a, b) => a + b, 0) : CFG.boss[st.boss].hp;
    return st.beats().length;
  }

  function startStage() {
    const st = LEVELS.STAGES[stageIdx];
    state = S.PLAY;
    stageScore = 0; playT = 0; healT = 0;      // life (hull) persists — NOT reset here
    bossCtl = null; bossModel = null;
    stageActions = actionsFor(st);

    guard('arm', () => armStage(st));

    guard('hud', () => {
      updateHull();
      if (ship) ship.setDamage(1 - hull / CFG.hull.max);
      $('intro').classList.add('hidden');
      $('results').classList.add('hidden');
      $('fail').classList.add('hidden');
      $('hud').classList.remove('hidden');
      $('hud-score').textContent = '0';
      $('hud-mult').textContent = '0';
      $('hud-stage-lbl').textContent = 'Stage ' + st.n;
      $('hud-stage-name').textContent = st.name;
      $('progress-fill').style.width = '0%';
      $('progress-fill').classList.remove('full');
      $('boss-bar').classList.toggle('hidden', st.kind !== 'boss');
    });

    guard('camera', () => {
      camera.position.set(0, st.cam.y, st.cam.z);
      camera.rotation.set(0, 0, 0);
      camera.lookAt(0, 0, 0);
    });

    guard('boss-clear', () => clear(bossRoot));
    guard('orbit-reset', () => { if (st.kind !== 'orbit') orbitOff(); });

    if (st.kind === 'orbit') {
      guard('orbit-start', () => {
        $('boss-bar').classList.add('hidden');
        $('hud-mult').textContent = '0';
        orbitOn();
      });
    } else if (st.kind === 'boss') {
      guard('boss-init', () => {
        bossCtl = BOSS.fight(st.boss, qte, {
          onDamage: (d, k) => guard('boss-dmg', () => {
            $('boss-fill').style.width = (k * 100) + '%';
            FX.kick(0.3); FX.flash(0.12, 80);
            if (bossModel) FX.burst(bossModel.obj.position, '#ff8a5c', 22, 6);
          }),
          onPhase: (p) => guard('boss-phase', () => {
            $('boss-phase').textContent = 'Phase ' + p + ' / ' + bossCtl.phases;
            FX.flash(0.5, 240); FX.kick(0.9);
          }),
          onTelegraph: () => { $('boss-phase').textContent = 'Incoming'; },
          onAttackWindow: () => { $('boss-phase').textContent = 'Opening \u2014 strike'; },
          onPlayerHit: () => { FX.kick(0.8); FX.flash(0.3, 160); },
          onDeath: () => guard('boss-death', () => {
            $('boss-phase').textContent = 'Destroyed';
            if (bossModel) FX.burst(bossModel.obj.position, '#ffd76b', 90, 14, 1.4);
            FX.flash(0.85, 500); FX.kick(1.2);
            setTimeout(() => guard('boss-end', () => { if (state === S.PLAY) endStage(true); }), 1400);
          })
        });
        $('boss-name').textContent = st.name;
        $('boss-fill').style.width = '100%';
        $('boss-phase').textContent = bossCtl.phases > 1 ? 'Phase 1 / ' + bossCtl.phases : '';
      });
      guard('boss-model', () => {
        bossModel = bossCtl.makeModel();
        bossModel.obj.position.set(0, 0.6, -14);
        bossRoot.add(bossModel.obj);
      });
    }
  }

  function endStage(cleared) {
    if (state !== S.PLAY) return;
    qte.stop();
    AUDIO.droneOff();
    const st = LEVELS.STAGES[stageIdx];
    let t = qte.tally;
    let orbitRate = null;
    if (st.kind === 'orbit' && orbitGame) {
      const os = orbitGame.stats;
      t = { perfect: os.perfect, hit: os.hops - os.perfect, miss: cleared ? 0 : 1, total: os.target };
      orbitRate = os.perfect >= 8 ? 96 : os.perfect >= 5 ? 86 : os.perfect >= 2 ? 72 : 55;
      orbitOff();
    }

    if (!cleared) {
      state = S.FAIL;
      $('hud').classList.add('hidden');
      $('fail').classList.remove('hidden');
      AUDIO.fanfare(false);
      return;
    }

    const rate = orbitRate !== null ? orbitRate : qte.hitRate();
    const g = rate >= CFG.grade.S ? 'S' : rate >= CFG.grade.A ? 'A' : rate >= CFG.grade.B ? 'B' : 'C';

    state = S.RESULTS;
    $('hud').classList.add('hidden');
    $('res-stage').textContent = 'Stage ' + st.n + ' clear \u00b7 ' + st.name;
    const gEl = $('res-grade');
    gEl.textContent = g; gEl.dataset.g = g;
    $('res-perfect').textContent = t.perfect;
    $('res-hit').textContent = t.hit;
    $('res-miss').textContent = t.miss;
    $('res-combo').textContent = stageScore.toLocaleString();
    $('res-score').textContent = '0';
    $('results').classList.remove('hidden');
    FX.countUp($('res-score'), stageScore, 650);
    AUDIO.fanfare(g === 'S' || g === 'A');

    results[stageIdx] = { name: st.name, n: st.n, grade: g, score: stageScore, rate };
    $('btn-next').textContent = stageIdx >= LEVELS.STAGES.length - 1 ? 'Touch down' : 'Continue';
  }

  function nextStage() {
    runScore = results.reduce((a, r) => a + (r ? r.score : 0), 0);
    if (stageIdx >= LEVELS.STAGES.length - 1) return showTally();
    stageIdx++;
    showIntro();
  }

  function showTally() {
    state = S.TALLY;
    runScore = results.reduce((a, r) => a + (r ? r.score : 0), 0);
    const list = $('tally-list');
    list.innerHTML = '';
    results.forEach((r) => {
      if (!r) return;
      const row = document.createElement('div');
      row.className = 'tally-row';
      const col = r.grade === 'S' ? 'var(--perfect)' : r.grade === 'A' ? 'var(--hit)'
        : r.grade === 'C' ? 'var(--dim)' : 'var(--ink)';
      row.innerHTML = '<span class="n">' + String(r.n).padStart(2, '0') + ' \u00b7 ' + r.name + '</span>' +
        '<span class="g" style="color:' + col + '">' + r.grade + '</span>' +
        '<span class="s">' + r.score.toLocaleString() + '</span>';
      list.appendChild(row);
    });
    $('tally-total').textContent = '0';
    FX.countUp($('tally-total'), runScore, 900);

    const isBest = runScore > sessionBest;
    if (isBest) {
      sessionBest = runScore;
      try { localStorage.setItem('outerstellar.best', String(sessionBest)); } catch (e) {}
    }
    $('tally-best').textContent = isBest ? 'NEW BEST' : 'Best \u00b7 ' + sessionBest.toLocaleString();
    $('results').classList.add('hidden');
    $('hud').classList.add('hidden');
    $('tally').classList.remove('hidden');
    AUDIO.fanfare(true);
    setTimeout(() => guard('tally-boom', () => AUDIO.boom()), 300);
  }


  // ---------- planetfall (free walk) ----------
  const W = {
    pos: new THREE.Vector3(0, 0, 4),
    vy: 0, heading: 0, camYaw: 0, cycle: 0, air: false, jumpSquash: 0, landRecover: 0,
    joy: { id: null, ox: 0, oy: 0, x: 0, y: 0 },
    look: { id: null, lx: 0 },
    keys: { x: 0, y: 0 },
    savedFog: null,
    score: 0, shards: 0, ringsHit: 0, travel: 0, best: 0,
    doneShards: false, doneRings: false, introSeen: false, paused: false,
    endgame: false, endgameDone: false, relics: 0, relicTotal: 5, summitDone: false
  };
  try { W.best = parseInt(localStorage.getItem('outerstellar.walkbest') || '0', 10) || 0; } catch (e) {}

  function walkBanner(text) {
    const b = $('walk-banner');
    b.textContent = text;
    b.classList.remove('hidden');
    // retrigger the CSS animation
    b.style.animation = 'none';
    void b.offsetWidth;
    b.style.animation = '';
  }
  function walkScore(add) {
