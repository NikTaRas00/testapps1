/* ===== src/audio.js ===== */
/* WebAudio synth — no asset files. */
const AUDIO = (() => {
  let ctx = null, master = null, muted = false, drone = null;
  const PENTA = [0, 2, 4, 7, 9, 12, 14, 16, 19, 21, 24, 26, 28];
  const BASE = 196; // G3

  function boot() {
    if (ctx) return ctx;
    const AC = window.AudioContext || window.webkitAudioContext;
    if (!AC) return null;
    ctx = new AC();
    master = ctx.createGain();
    master.gain.value = 0.5;
    master.connect(ctx.destination);
    return ctx;
  }
  function unlock() { // iOS
    boot();
    if (ctx && ctx.state === 'suspended') ctx.resume();
  }
  const now = () => (ctx ? ctx.currentTime : 0);

  function tone(freq, dur, type = 'sine', gain = 0.25, glide = 0) {
    if (!ctx || muted) return;
    const o = ctx.createOscillator(), g = ctx.createGain();
    o.type = type;
    o.frequency.setValueAtTime(freq, now());
    if (glide) o.frequency.exponentialRampToValueAtTime(Math.max(30, freq * glide), now() + dur);
    g.gain.setValueAtTime(0.0001, now());
    g.gain.exponentialRampToValueAtTime(gain, now() + 0.008);
    g.gain.exponentialRampToValueAtTime(0.0001, now() + dur);
    o.connect(g); g.connect(master);
    o.start(); o.stop(now() + dur + 0.02);
  }

  function noiz(dur, gain = 0.2, filt = 1200, sweep = 0) {
    if (!ctx || muted) return;
    const n = Math.floor(ctx.sampleRate * dur);
    const buf = ctx.createBuffer(1, n, ctx.sampleRate);
    const d = buf.getChannelData(0);
    for (let i = 0; i < n; i++) d[i] = (Math.random() * 2 - 1) * (1 - i / n);
    const s = ctx.createBufferSource(); s.buffer = buf;
    const bp = ctx.createBiquadFilter();
    bp.type = 'bandpass'; bp.frequency.setValueAtTime(filt, now()); bp.Q.value = 0.9;
    if (sweep) bp.frequency.exponentialRampToValueAtTime(Math.max(60, filt * sweep), now() + dur);
    const g = ctx.createGain();
    g.gain.setValueAtTime(gain, now());
    g.gain.exponentialRampToValueAtTime(0.0001, now() + dur);
    s.connect(bp); bp.connect(g); g.connect(master);
    s.start(); s.stop(now() + dur);
  }

  const semi = (n) => BASE * Math.pow(2, n / 12);

  return {
    unlock, boot,
    get muted() { return muted; },
    toggle() { muted = !muted; if (muted) this.droneOff(); return muted; },

    hit(combo) {
      const step = PENTA[Math.min(combo, PENTA.length - 1)];
      tone(semi(step), 0.22, 'triangle', 0.22);
      tone(semi(step + 12), 0.10, 'sine', 0.08);
    },
    perfect(combo) {
      const step = PENTA[Math.min(combo, PENTA.length - 1)];
      tone(semi(step), 0.30, 'triangle', 0.26);
      tone(semi(step + 7), 0.24, 'sine', 0.14);
      tone(semi(step + 19), 0.18, 'sine', 0.07);
    },
    miss() { tone(88, 0.30, 'sawtooth', 0.16, 0.5); noiz(0.16, 0.10, 500, 0.4); },
    whoosh() { noiz(0.34, 0.14, 900, 0.25); },
    mash() { tone(320 + Math.random() * 120, 0.05, 'square', 0.08); },
    boom() {
      noiz(0.9, 0.34, 240, 0.15);
      tone(58, 0.7, 'sine', 0.28, 0.4);
    },
    ui() { tone(660, 0.06, 'sine', 0.10); },
    bossHit() { noiz(0.14, 0.2, 1800, 0.3); tone(147, 0.16, 'square', 0.12, 0.6); },
    fanfare(good) {
      const n = good ? [0, 4, 7, 12] : [0, 3, 5];
      n.forEach((s, i) => setTimeout(() => tone(semi(s + 12), 0.35, 'triangle', 0.2), i * 110));
    },
    droneOn() {
      if (!ctx || muted || drone) return;
      const o = ctx.createOscillator(), o2 = ctx.createOscillator(), g = ctx.createGain();
      o.type = 'sawtooth'; o.frequency.value = 55;
      o2.type = 'sine'; o2.frequency.value = 55.7;
      g.gain.setValueAtTime(0.0001, now());
      g.gain.exponentialRampToValueAtTime(0.06, now() + 0.6);
      o.connect(g); o2.connect(g); g.connect(master);
      o.start(); o2.start();
      drone = { o, o2, g };
    },
    droneOff() {
      if (!drone || !ctx) return;
      const d = drone; drone = null;
      try {
        d.g.gain.cancelScheduledValues(now());
        d.g.gain.setValueAtTime(d.g.gain.value || 0.0001, now());
        d.g.gain.exponentialRampToValueAtTime(0.0001, now() + 0.4);
        d.o.stop(now() + 0.45); d.o2.stop(now() + 0.45);
      } catch (e) { /* already stopped */ }
    }
  };
})();

/* ===== src/input.js ===== */
/* Pointer + keyboard → normalized QTE inputs. One thumb must be enough. */
const INPUT = (() => {
  const SWIPE_DIST = 24, SWIPE_TIME = 180;
  const listeners = [];
  let down = false, sx = 0, sy = 0, st = 0, swiped = false, holdKey = false;
  let enabled = true;

  const emit = (type, data) => { if (enabled) listeners.forEach(f => f(type, data || {})); };
  const on = (fn) => listeners.push(fn);

  function dirOf(dx, dy) {
    return Math.abs(dx) > Math.abs(dy)
      ? (dx > 0 ? 'right' : 'left')
      : (dy > 0 ? 'down' : 'up');
  }

  function attach(el) {
    el.addEventListener('pointerdown', (e) => {
      if (e.target.closest('button')) return;
      AUDIO.unlock();
      el.setPointerCapture && el.setPointerCapture(e.pointerId);
      down = true; swiped = false;
      sx = e.clientX; sy = e.clientY; st = performance.now();
      emit('down', { x: sx, y: sy });
      emit('mash', {});
    }, { passive: true });

    el.addEventListener('pointermove', (e) => {
      if (!down || swiped) return;
      const dx = e.clientX - sx, dy = e.clientY - sy;
      if (Math.hypot(dx, dy) >= SWIPE_DIST && performance.now() - st <= SWIPE_TIME) {
        swiped = true;
        emit('swipe', { dir: dirOf(dx, dy) });
      }
    }, { passive: true });

    const up = (e) => {
      if (!down) return;
      down = false;
      const dt = performance.now() - st;
      const dx = (e.clientX || sx) - sx, dy = (e.clientY || sy) - sy;
      if (!swiped && Math.hypot(dx, dy) >= SWIPE_DIST && dt <= SWIPE_TIME) {
        swiped = true;
        emit('swipe', { dir: dirOf(dx, dy) });
      }
      emit('up', { held: dt });
      if (!swiped) emit('tap', { held: dt });
    };
    el.addEventListener('pointerup', up, { passive: true });
    el.addEventListener('pointercancel', () => { down = false; emit('up', { held: 0 }); }, { passive: true });

    window.addEventListener('keydown', (e) => {
      if (e.repeat) {
        if (e.code === 'Space') e.preventDefault();
        return;
      }
      const k = e.code;
      if (k === 'Space') {
        e.preventDefault();
        holdKey = true;
        AUDIO.unlock();
        emit('down', {}); emit('mash', {});
        return;
      }
      if (k === 'Enter' || k === 'KeyF') { AUDIO.unlock(); emit('down', {}); emit('mash', {}); emit('tap', { held: 0 }); emit('up', { held: 0 }); return; }
      const map = {
        ArrowUp: 'up', KeyW: 'up', ArrowDown: 'down', KeyS: 'down',
        ArrowLeft: 'left', KeyA: 'left', ArrowRight: 'right', KeyD: 'right'
      };
      if (map[k]) { e.preventDefault(); emit('swipe', { dir: map[k] }); }
    });

    window.addEventListener('keyup', (e) => {
      if (e.code === 'Space' && holdKey) {
        holdKey = false;
        emit('up', {}); emit('tap', {});
      }
    });
  }

  return {
    attach, on,
    set enabled(v) { enabled = v; },
    get enabled() { return enabled; },
    get isDown() { return down || holdKey; }
  };
})();

/* ===== src/fx.js ===== */
/* Juice: particle bursts, camera shake, flashes, DOM floats. */
const FX = (() => {
  const bursts = [];
  let scene = null, camera = null, shake = 0, hitstop = 0, flashEl = null;
  const floatsEl = () => document.getElementById('floats');

  function dot(size, color) {
    const c = document.createElement('canvas');
    c.width = c.height = 64;
    const g = c.getContext('2d');
    const rg = g.createRadialGradient(32, 32, 0, 32, 32, 32);
    rg.addColorStop(0, 'rgba(255,255,255,1)');
    rg.addColorStop(0.35, color);
    rg.addColorStop(1, 'rgba(0,0,0,0)');
    g.fillStyle = rg; g.fillRect(0, 0, 64, 64);
    const t = new THREE.CanvasTexture(c);
    return new THREE.PointsMaterial({
      size, map: t, transparent: true, depthWrite: false,
      blending: THREE.AdditiveBlending, sizeAttenuation: true
    });
  }

  function init(sc, cam) {
    scene = sc; camera = cam;
    flashEl = document.createElement('div');
    flashEl.id = 'flash';
    document.getElementById('stage').appendChild(flashEl);
  }

  function burst(pos, color = '#7fd6ff', count = 26, spread = 5, life = 0.8) {
    if (!scene) return;
    const n = CFG.reduced ? Math.floor(count / 3) : count;
    const geo = new THREE.BufferGeometry();
    const p = new Float32Array(n * 3), v = [];
    for (let i = 0; i < n; i++) {
      p[i * 3] = pos.x; p[i * 3 + 1] = pos.y; p[i * 3 + 2] = pos.z;
      v.push(new THREE.Vector3(
        (Math.random() - 0.5) * spread,
        (Math.random() - 0.5) * spread,
        (Math.random() - 0.5) * spread
      ));
    }
    geo.setAttribute('position', new THREE.BufferAttribute(p, 3));
    const mat = dot(0.55, color);
    const pts = new THREE.Points(geo, mat);
    scene.add(pts);
    bursts.push({ pts, v, t: 0, life });
  }

  function update(dt) {
    for (let i = bursts.length - 1; i >= 0; i--) {
      const b = bursts[i];
      b.t += dt;
      const arr = b.pts.geometry.attributes.position.array;
      for (let j = 0; j < b.v.length; j++) {
        arr[j * 3] += b.v[j].x * dt;
        arr[j * 3 + 1] += b.v[j].y * dt;
        arr[j * 3 + 2] += b.v[j].z * dt;
        b.v[j].multiplyScalar(0.94);
      }
      b.pts.geometry.attributes.position.needsUpdate = true;
      b.pts.material.opacity = Math.max(0, 1 - b.t / b.life);
      if (b.t >= b.life) {
        scene.remove(b.pts);
        b.pts.geometry.dispose();
        b.pts.material.map.dispose();
        b.pts.material.dispose();
        bursts.splice(i, 1);
      }
    }
    if (shake > 0 && camera) {
      shake = Math.max(0, shake - dt * 2.4);
      const s = shake * (CFG.reduced ? 0.2 : 1);
      camera.position.x += (Math.random() - 0.5) * s;
      camera.position.y += (Math.random() - 0.5) * s;
      camera.rotation.z += (Math.random() - 0.5) * s * 0.02;
    }
    if (hitstop > 0) hitstop = Math.max(0, hitstop - dt);
  }

  return {
    init, burst, update,
    kick(amount) { shake = Math.min(1.2, shake + amount); },
    freeze(ms) { hitstop = ms / 1000; },
    get frozen() { return hitstop > 0; },
    flash(alpha = 0.4, ms = 120) {
      if (!flashEl || CFG.reduced) return;
      flashEl.style.transition = 'none';
      flashEl.style.opacity = alpha;
      requestAnimationFrame(() => {
        flashEl.style.transition = `opacity ${ms}ms ease-out`;
        flashEl.style.opacity = 0;
      });
    },
    float(x, y, text, cls) {
      const el = document.createElement('div');
      el.className = 'float ' + cls;
      el.textContent = text;
      el.style.left = x + 'px';
      el.style.top = y + 'px';
      floatsEl().appendChild(el);
      setTimeout(() => el.remove(), 850);
    },
    countUp(el, to, ms = 500) {
      const from = parseInt(el.textContent.replace(/\D/g, ''), 10) || 0;
      if (CFG.reduced || from === to) { el.textContent = to.toLocaleString(); return; }
      const t0 = performance.now();
      const step = () => {
        const k = Math.min(1, (performance.now() - t0) / ms);
        const e = 1 - Math.pow(1 - k, 3);
        el.textContent = Math.round(from + (to - from) * e).toLocaleString();
        if (k < 1) requestAnimationFrame(step);
      };
      step();
    }
  };
})();

/* ===== src/space.js ===== */
/* Procedural deep space: stars, milky-way band, nebulae, sun + glare, lit planet. */
const SPACE = (() => {
  function starTex() {
    const c = document.createElement('canvas');
    c.width = c.height = 32;
    const g = c.getContext('2d');
    const rg = g.createRadialGradient(16, 16, 0, 16, 16, 16);
    rg.addColorStop(0, 'rgba(255,255,255,1)');
    rg.addColorStop(0.25, 'rgba(255,255,255,.75)');
    rg.addColorStop(1, 'rgba(255,255,255,0)');
    g.fillStyle = rg; g.fillRect(0, 0, 32, 32);
    return new THREE.CanvasTexture(c);
  }

  function nebulaTex(hue) {
    const S = 256;
    const c = document.createElement('canvas');
    c.width = c.height = S;
    const g = c.getContext('2d');
    g.clearRect(0, 0, S, S);
    for (let i = 0; i < 26; i++) {
      const x = S / 2 + (Math.random() - 0.5) * S * 0.75;
      const y = S / 2 + (Math.random() - 0.5) * S * 0.75;
      const r = 22 + Math.random() * 78;
      const rg = g.createRadialGradient(x, y, 0, x, y, r);
      const h = hue + (Math.random() - 0.5) * 40;
      rg.addColorStop(0, `hsla(${h},70%,62%,${0.10 + Math.random() * 0.10})`);
      rg.addColorStop(1, `hsla(${h},70%,40%,0)`);
      g.fillStyle = rg;
      g.beginPath(); g.arc(x, y, r, 0, 7); g.fill();
    }
    // soften edges to a circle
    g.globalCompositeOperation = 'destination-in';
    const mask = g.createRadialGradient(S / 2, S / 2, S * 0.1, S / 2, S / 2, S / 2);
    mask.addColorStop(0, 'rgba(0,0,0,1)');
    mask.addColorStop(1, 'rgba(0,0,0,0)');
    g.fillStyle = mask; g.fillRect(0, 0, S, S);
    return new THREE.CanvasTexture(c);
  }

  function glowTex(inner, outer) {
    const S = 256;
    const c = document.createElement('canvas');
    c.width = c.height = S;
    const g = c.getContext('2d');
    const rg = g.createRadialGradient(S / 2, S / 2, 0, S / 2, S / 2, S / 2);
    rg.addColorStop(0, inner);
    rg.addColorStop(0.12, inner);
    rg.addColorStop(0.3, outer);
    rg.addColorStop(1, 'rgba(0,0,0,0)');
    g.fillStyle = rg; g.fillRect(0, 0, S, S);
    return new THREE.CanvasTexture(c);
  }

  function planetTex(base, land) {
    const W = 512, H = 256;
    const c = document.createElement('canvas');
    c.width = W; c.height = H;
    const g = c.getContext('2d');
    g.fillStyle = base; g.fillRect(0, 0, W, H);
    for (let i = 0; i < 90; i++) {
      const x = Math.random() * W, y = Math.random() * H;
      const r = 10 + Math.random() * 60;
      const rg = g.createRadialGradient(x, y, 0, x, y, r);
      rg.addColorStop(0, land.replace('ALPHA', 0.18 + Math.random() * 0.3));
      rg.addColorStop(1, land.replace('ALPHA', 0));
      g.fillStyle = rg;
      g.beginPath(); g.ellipse(x, y, r, r * 0.55, Math.random() * 3, 0, 7); g.fill();
    }
    // fine grain
    const img = g.getImageData(0, 0, W, H), d = img.data;
    for (let i = 0; i < d.length; i += 4) {
      const n = (Math.random() - 0.5) * 16;
      d[i] += n; d[i + 1] += n; d[i + 2] += n;
    }
    g.putImageData(img, 0, 0);
    return new THREE.CanvasTexture(c);
  }

  function cloudTex() {
    const W = 512, H = 256;
    const c = document.createElement('canvas');
    c.width = W; c.height = H;
    const g = c.getContext('2d');
    g.clearRect(0, 0, W, H);
    for (let i = 0; i < 130; i++) {
      const x = Math.random() * W, y = Math.random() * H;
      const r = 8 + Math.random() * 46;
      const rg = g.createRadialGradient(x, y, 0, x, y, r);
      const a = 0.05 + Math.random() * 0.22;
      rg.addColorStop(0, `rgba(255,255,255,${a})`);
      rg.addColorStop(1, 'rgba(255,255,255,0)');
      g.fillStyle = rg;
      g.beginPath(); g.ellipse(x, y, r * 1.5, r * 0.6, 0, 0, 7); g.fill();
    }
    return new THREE.CanvasTexture(c);
  }

  function build(scene) {
    const grp = new THREE.Group();

    // --- stars (dense field + milky-way band) ---
    const N = 6000, pos = new Float32Array(N * 3), col = new Float32Array(N * 3);
    const R = 900;
    const cTmp = new THREE.Color();
    for (let i = 0; i < N; i++) {
      let x, y, z;
      if (i % 3 === 0) { // band: flatten toward a plane, then tilt
        const a = Math.random() * Math.PI * 2;
        const r = R * (0.7 + Math.random() * 0.3);
        const t = (Math.random() - 0.5) * 0.22;
        x = Math.cos(a) * r; z = Math.sin(a) * r; y = t * r;
        const s = Math.sin(0.5), cs = Math.cos(0.5);
        const y2 = y * cs - z * s, z2 = y * s + z * cs;
        y = y2; z = z2;
      } else {
        const u = Math.random() * 2 - 1, a = Math.random() * Math.PI * 2;
        const s = Math.sqrt(1 - u * u), r = R * (0.6 + Math.random() * 0.4);
        x = s * Math.cos(a) * r; y = s * Math.sin(a) * r; z = u * r;
      }
      pos[i * 3] = x; pos[i * 3 + 1] = y; pos[i * 3 + 2] = z;
      const t = Math.random();
      cTmp.setHSL(t < 0.72 ? 0.58 : (t < 0.9 ? 0.09 : 0.02), t < 0.72 ? 0.12 : 0.45, 0.55 + Math.random() * 0.45);
      col[i * 3] = cTmp.r; col[i * 3 + 1] = cTmp.g; col[i * 3 + 2] = cTmp.b;
    }
    const sGeo = new THREE.BufferGeometry();
    sGeo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
    sGeo.setAttribute('color', new THREE.BufferAttribute(col, 3));
    const stars = new THREE.Points(sGeo, new THREE.PointsMaterial({
      size: 2.4, map: starTex(), vertexColors: true, transparent: true,
      depthWrite: false, blending: THREE.AdditiveBlending, sizeAttenuation: true
    }));
    grp.add(stars);

    // --- nebulae ---
    const hues = [212, 268, 196, 320, 238, 180];
    hues.forEach((h, i) => {
      const m = new THREE.SpriteMaterial({
        map: nebulaTex(h), transparent: true, opacity: 0.42,
        depthWrite: false, blending: THREE.AdditiveBlending
      });
      const sp = new THREE.Sprite(m);
      const a = (i / hues.length) * Math.PI * 2 + Math.random();
      const r = 520 + Math.random() * 220;
      sp.position.set(Math.cos(a) * r, (Math.random() - 0.5) * 380, Math.sin(a) * r);
      const s = 320 + Math.random() * 380;
      sp.scale.set(s, s * (0.6 + Math.random() * 0.5), 1);
      grp.add(sp);
    });

    // --- sun + glare ---
    const sun = new THREE.Sprite(new THREE.SpriteMaterial({
      map: glowTex('rgba(255,255,255,1)', 'rgba(255,214,150,.45)'),
      transparent: true, depthWrite: false, blending: THREE.AdditiveBlending
    }));
    sun.position.set(-320, 190, -640);
    sun.scale.set(180, 180, 1);
    grp.add(sun);

    const glare = new THREE.Sprite(new THREE.SpriteMaterial({
      map: glowTex('rgba(255,236,200,.35)', 'rgba(255,180,110,.08)'),
      transparent: true, opacity: 0.7, depthWrite: false, blending: THREE.AdditiveBlending
    }));
    glare.position.copy(sun.position);
    glare.scale.set(620, 620, 1);
    grp.add(glare);

    // --- planet: surface + clouds + atmosphere rim ---
    const planet = new THREE.Group();
    const surf = new THREE.Mesh(
      new THREE.SphereGeometry(60, 64, 48),
      new THREE.MeshStandardMaterial({
        map: planetTex('#1d3a5c', 'rgba(96,168,120,ALPHA)'),
        roughness: 0.92, metalness: 0.02
      })
    );
    surf.receiveShadow = true;
    planet.add(surf);

    const clouds = new THREE.Mesh(
      new THREE.SphereGeometry(61.2, 48, 32),
      new THREE.MeshStandardMaterial({
        map: cloudTex(), transparent: true, opacity: 0.55,
        roughness: 1, metalness: 0, depthWrite: false
      })
    );
    planet.add(clouds);

    const atmo = new THREE.Mesh(
      new THREE.SphereGeometry(66, 48, 32),
      new THREE.ShaderMaterial({
        transparent: true, side: THREE.BackSide, depthWrite: false,
        blending: THREE.AdditiveBlending,
        uniforms: { uColor: { value: new THREE.Color('#7fc4ff') } },
        vertexShader: `
          varying vec3 vN; varying vec3 vP;
          void main(){
            vN = normalize(normalMatrix * normal);
            vec4 mv = modelViewMatrix * vec4(position,1.0);
            vP = mv.xyz;
            gl_Position = projectionMatrix * mv;
          }`,
        fragmentShader: `
          uniform vec3 uColor; varying vec3 vN; varying vec3 vP;
          void main(){
            float f = pow(1.0 - abs(dot(normalize(vN), normalize(-vP))), 3.0);
            gl_FragColor = vec4(uColor, f * 0.85);
          }`
      })
    );
    planet.add(atmo);

    planet.position.set(140, -30, -520);
    grp.add(planet);

    scene.add(grp);

    // --- lights ---
    const key = new THREE.DirectionalLight(0xfff0dc, 2.4);
    key.position.set(-8, 5, 3);
    key.castShadow = true;
    key.shadow.mapSize.set(1024, 1024);
    key.shadow.camera.near = 0.5; key.shadow.camera.far = 60;
    scene.add(key);

    const rim = new THREE.DirectionalLight(0x5b8fd6, 0.7);
    rim.position.set(6, -2, -5);
    scene.add(rim);

    scene.add(new THREE.AmbientLight(0x2a3550, 0.55));

    return {
      group: grp, stars, planet, surf, clouds, sun,
      update(dt, t) {
        stars.rotation.y += dt * 0.004;
        surf.rotation.y += dt * 0.012;
        clouds.rotation.y += dt * 0.018;
        planet.rotation.z = Math.sin(t * 0.1) * 0.02;
      },
      // pull the planet in as the run progresses (0..1)
      approach(k) {
        planet.position.z = -520 + k * 380;
        planet.position.x = 140 - k * 95;
        planet.position.y = -30 + k * 12;
      }
    };
  }

  return { build, glowTex, planetTex };
})();

/* ===== src/walk.js ===== */
/* PLANETFALL: procedural surface you can actually walk on.
   Rolling terrain from layered sines (analytic height = free collision),
   scattered rocks, a flag at the landing site. Zero assets. */
const WALK = (() => {
  const SIZE = 260;

  function height(x, z) {
    return Math.sin(x * 0.075) * 1.5
         + Math.cos(z * 0.06) * 1.8
         + Math.sin((x + z) * 0.042) * 2.2
         + Math.sin(x * 0.23 + z * 0.19) * 0.45;
  }

  function groundTex() {
    const S = 512;
    const c = document.createElement('canvas');
    c.width = c.height = S;
    const g = c.getContext('2d');
    g.fillStyle = '#2f5a52';
    g.fillRect(0, 0, S, S);
    // mineral patches
    for (let i = 0; i < 70; i++) {
      const x = Math.random() * S, y = Math.random() * S, r = 14 + Math.random() * 70;
      const rg = g.createRadialGradient(x, y, 0, x, y, r);
      const hue = 150 + Math.random() * 60;
      rg.addColorStop(0, `hsla(${hue},26%,${24 + Math.random() * 14}%,${0.25 + Math.random() * 0.3})`);
      rg.addColorStop(1, 'hsla(0,0%,0%,0)');
      g.fillStyle = rg;
      g.beginPath(); g.ellipse(x, y, r, r * 0.6, Math.random() * 3, 0, 7); g.fill();
    }
    // grit
    const img = g.getImageData(0, 0, S, S), d = img.data;
    for (let i = 0; i < d.length; i += 4) {
      const n = (Math.random() - 0.5) * 22;
      d[i] += n; d[i + 1] += n; d[i + 2] += n;
    }
    g.putImageData(img, 0, 0);
    const t = new THREE.CanvasTexture(c);
    t.wrapS = t.wrapT = THREE.RepeatWrapping;
    t.repeat.set(6, 6);
    return t;
  }

  function build(scene) {
    const grp = new THREE.Group();
    grp.visible = false;

    // --- sky dome: gradient from horizon haze to deep teal-black ---
    const skyGeo = new THREE.SphereGeometry(600, 32, 20);
    const skyMat = new THREE.ShaderMaterial({
      side: THREE.BackSide, depthWrite: false, fog: false,
      uniforms: {
        top: { value: new THREE.Color('#0a1826') },
        mid: { value: new THREE.Color('#1e4a3c') },
        hor: { value: new THREE.Color('#4a8268') }
      },
      vertexShader: 'varying vec3 vP; void main(){ vP = position; gl_Position = projectionMatrix * modelViewMatrix * vec4(position,1.0); }',
      fragmentShader: [
        'uniform vec3 top; uniform vec3 mid; uniform vec3 hor; varying vec3 vP;',
        'void main(){',
        '  float h = normalize(vP).y;',
        '  vec3 c = h > 0.0 ? mix(mid, top, pow(h, 0.6)) : mix(mid, hor, pow(-h, 0.5));',
        '  gl_FragColor = vec4(c, 1.0);',
        '}'
      ].join('\n')
    });
    const sky = new THREE.Mesh(skyGeo, skyMat);
    grp.add(sky);

    // --- terrain with elevation-based vertex color ---
    const geo = new THREE.PlaneGeometry(SIZE, SIZE, 128, 128);
    geo.rotateX(-Math.PI / 2);
    const pos = geo.attributes.position;
    const col = new Float32Array(pos.count * 3);
    const cLow = new THREE.Color('#28524a');    // mossy valley
    const cMid = new THREE.Color('#437267');    // slope
    const cHigh = new THREE.Color('#8fb0a8');   // pale rock crest
    const tmp = new THREE.Color();
    for (let i = 0; i < pos.count; i++) {
      const x = pos.getX(i), z = pos.getZ(i);
      const y = height(x, z);
      pos.setY(i, y);
      const k = Math.max(0, Math.min(1, (y + 3.5) / 8));   // -3.5..4.5 -> 0..1
      if (k < 0.5) tmp.copy(cLow).lerp(cMid, k * 2);
      else tmp.copy(cMid).lerp(cHigh, (k - 0.5) * 2);
      col[i * 3] = tmp.r; col[i * 3 + 1] = tmp.g; col[i * 3 + 2] = tmp.b;
    }
    geo.setAttribute('color', new THREE.BufferAttribute(col, 3));
    geo.computeVertexNormals();
    const ground = new THREE.Mesh(geo, new THREE.MeshStandardMaterial({
      map: groundTex(), vertexColors: true, roughness: 0.96, metalness: 0.02
    }));
    ground.receiveShadow = true;
    grp.add(ground);

    // --- distant ridgeline: silhouette ring for horizon depth ---
    const ridgeMat = new THREE.MeshStandardMaterial({
      color: '#14312a', roughness: 1, metalness: 0, fog: true
    });
    for (let ring = 0; ring < 2; ring++) {
      const rad = SIZE / 2 + 40 + ring * 55;
      const segs = 40;
      for (let i = 0; i < segs; i++) {
        const a = (i / segs) * Math.PI * 2;
        const peak = new THREE.Mesh(
          new THREE.ConeGeometry(14 + Math.random() * 10, 22 + Math.random() * 34, 5),
          ridgeMat
        );
        peak.position.set(Math.cos(a) * rad, -2 - ring * 3, Math.sin(a) * rad);
        peak.rotation.y = Math.random() * 3;
        grp.add(peak);
      }
    }

    // --- rocks (recorded as colliders: circle in XZ + top height for jump-over) ---
    const rockMat = new THREE.MeshStandardMaterial({ color: '#46635e', roughness: 0.9, metalness: 0.05 });
    const rockMat2 = new THREE.MeshStandardMaterial({ color: '#38504b', roughness: 0.95, metalness: 0.02 });
    const colliders = [];
    for (let i = 0; i < 52; i++) {
      const r = 0.4 + Math.random() * 2.6;
      const rock = new THREE.Mesh(new THREE.IcosahedronGeometry(r, 0), Math.random() < 0.5 ? rockMat : rockMat2);
      const a = Math.random() * Math.PI * 2;
      const d = 8 + Math.random() * (SIZE / 2 - 22);
      const x = Math.cos(a) * d, z = Math.sin(a) * d;
      const y0 = height(x, z);
      rock.position.set(x, y0 + r * 0.25, z);
      rock.rotation.set(Math.random() * 3, Math.random() * 3, Math.random() * 3);
      const sy = 0.55 + Math.random() * 0.5;
      rock.scale.y = sy;
      rock.castShadow = true;
      grp.add(rock);
      colliders.push({ x, z, r: r * 0.82, top: y0 + r * sy * 0.9 });
    }

    // --- alien flora: glowing spore stalks, scattered ---
    const stalkMat = new THREE.MeshStandardMaterial({ color: '#1d3b34', roughness: 0.8 });
    const budMat = new THREE.MeshStandardMaterial({
      color: '#8affd0', emissive: '#2fae7e', emissiveIntensity: 0.9, roughness: 0.5
    });
    const flora = [];
    for (let i = 0; i < 40; i++) {
      const a = Math.random() * Math.PI * 2;
      const d = 10 + Math.random() * (SIZE / 2 - 20);
      const x = Math.cos(a) * d, z = Math.sin(a) * d;
      const y0 = height(x, z);
      const stem = new THREE.Group();
      const h = 0.7 + Math.random() * 1.1;
      const stalk = new THREE.Mesh(new THREE.CylinderGeometry(0.03, 0.06, h, 6), stalkMat);
      stalk.position.y = h / 2;
      const bud = new THREE.Mesh(new THREE.SphereGeometry(0.11 + Math.random() * 0.08, 8, 6), budMat);
      bud.position.y = h;
      stem.add(stalk, bud);
      stem.position.set(x, y0, z);
      grp.add(stem);
      flora.push({ stem, ph: Math.random() * 6, h });
    }

    // --- landing flag ---
    const pole = new THREE.Mesh(
      new THREE.CylinderGeometry(0.035, 0.035, 2.4, 8),
      new THREE.MeshStandardMaterial({ color: '#c9cfd8', metalness: 0.7, roughness: 0.4 })
    );
    const fx = 2.5, fz = -2.5;
    pole.position.set(fx, height(fx, fz) + 1.2, fz);
    grp.add(pole);
    const banner = new THREE.Mesh(
      new THREE.PlaneGeometry(1.1, 0.65),
      new THREE.MeshStandardMaterial({ color: '#ffd76b', roughness: 0.8, side: THREE.DoubleSide, emissive: '#4a3a00', emissiveIntensity: 0.3 })
    );
    banner.position.set(fx + 0.58, height(fx, fz) + 2.0, fz);
    grp.add(banner);

    // ================= QUEST LAYER =================
    // deterministic placement so runs are comparable
    let seed = 7;
    const rnd = () => ((seed = (seed * 1103515245 + 12345) & 0x7fffffff) / 0x7fffffff);

    function glowSprite(color, size) {
      const c = document.createElement('canvas');
      c.width = c.height = 64;
      const g = c.getContext('2d');
      const rg = g.createRadialGradient(32, 32, 0, 32, 32, 32);
      rg.addColorStop(0, 'rgba(255,255,255,.95)');
      rg.addColorStop(0.3, color);
      rg.addColorStop(1, 'rgba(0,0,0,0)');
      g.fillStyle = rg; g.fillRect(0, 0, 64, 64);
      const sp = new THREE.Sprite(new THREE.SpriteMaterial({
        map: new THREE.CanvasTexture(c), transparent: true,
        depthWrite: false, blending: THREE.AdditiveBlending
      }));
      sp.scale.set(size, size, 1);
      return sp;
    }

    // --- star shards (12): crystal + glow + light pillar beacon ---
    const shardMat = new THREE.MeshStandardMaterial({
      color: '#9fe8ff', emissive: '#3fb8e8', emissiveIntensity: 1.6,
      metalness: 0.3, roughness: 0.15
    });
    const pillarMat = new THREE.MeshStandardMaterial({
      color: '#7fd6ff', emissive: '#7fd6ff', emissiveIntensity: 0.5,
      transparent: true, opacity: 0.13, depthWrite: false
    });
    const shards = [];
    for (let i = 0; i < 12; i++) {
      const a = (i / 12) * Math.PI * 2 + rnd() * 0.5;
      const d = 16 + rnd() * (SIZE / 2 - 34);
      const x = Math.cos(a) * d, z = Math.sin(a) * d;
      const y0 = height(x, z);
      const node = new THREE.Group();
      const gem = new THREE.Mesh(new THREE.IcosahedronGeometry(0.42, 0), shardMat);
      gem.scale.y = 1.7;
      node.add(gem);
      node.add(glowSprite('rgba(127,214,255,.7)', 2.6));
      const pillar = new THREE.Mesh(new THREE.CylinderGeometry(0.16, 0.34, 34, 8, 1, true), pillarMat);
      pillar.position.y = 17;
      node.add(pillar);
      node.position.set(x, y0 + 0.9, z);
      grp.add(node);
      shards.push({ node, gem, pillar, x, z, y0, taken: false, ph: rnd() * 6 });
    }

    // --- jump rings (5): 3 low (jumpable), 2 high (geyser-launch only) ---
    const ringMat = new THREE.MeshStandardMaterial({
      color: '#ffd76b', emissive: '#c89a2e', emissiveIntensity: 1.1,
      metalness: 0.5, roughness: 0.3
    });
    const rings = [];
    const ringSpots = [[14, 10, 1.35], [-20, 18, 1.3], [26, -22, 1.4], [-6, -30, 4.2], [34, 14, 4.6]];
    ringSpots.forEach(([x, z, h], i) => {
      const y0 = height(x, z);
      const node = new THREE.Group();
      const torus = new THREE.Mesh(new THREE.TorusGeometry(1.05, 0.09, 10, 36), ringMat);
      node.add(torus);
      node.add(glowSprite('rgba(255,215,107,.5)', 3.4));
      node.position.set(x, y0 + h, z);
      grp.add(node);
      rings.push({ node, torus, x, z, y: y0 + h, passed: false, high: h > 3, ph: i * 1.3 });
    });

    // --- geysers (3): step on the vent, get launched ---
    const ventMat = new THREE.MeshStandardMaterial({ color: '#1b2f2b', roughness: 0.9 });
    const geysers = [];
    const geyserSpots = [[-8, -26, 0], [30, 10, 0], [-26, 6, 0]];
    geyserSpots.forEach(([x, z]) => {
      const y0 = height(x, z);
      const vent = new THREE.Mesh(new THREE.CylinderGeometry(1.3, 1.7, 0.5, 14), ventMat);
      vent.position.set(x, y0 + 0.15, z);
      grp.add(vent);
      const glow = glowSprite('rgba(160,255,220,.55)', 3.2);
      glow.position.set(x, y0 + 0.7, z);
      grp.add(glow);
      // steam column: pooled points
      const N = 34;
      const pgeo = new THREE.BufferGeometry();
      pgeo.setAttribute('position', new THREE.BufferAttribute(new Float32Array(N * 3), 3));
      const c2 = document.createElement('canvas');
      c2.width = c2.height = 32;
      const g2 = c2.getContext('2d');
      const rg2 = g2.createRadialGradient(16, 16, 0, 16, 16, 16);
      rg2.addColorStop(0, 'rgba(190,255,230,.9)');
      rg2.addColorStop(1, 'rgba(0,0,0,0)');
      g2.fillStyle = rg2; g2.fillRect(0, 0, 32, 32);
      const pts = new THREE.Points(pgeo, new THREE.PointsMaterial({
        size: 0.7, map: new THREE.CanvasTexture(c2), transparent: true,
        depthWrite: false, blending: THREE.AdditiveBlending, opacity: 0.7
      }));
      pts.position.set(x, y0 + 0.4, z);
      grp.add(pts);
      const seeds = [];
      for (let i = 0; i < N; i++) seeds.push(Math.random());
      geysers.push({ x, z, y0, pts, seeds, glow, cool: 0 });
    });

    // --- footprints: pooled, fading ---
    const PRINTS = 44;
    const prints = [];
    for (let i = 0; i < PRINTS; i++) {
      const p = new THREE.Mesh(new THREE.CircleGeometry(0.13, 8),
        new THREE.MeshStandardMaterial({
          color: '#101d1a', roughness: 1, transparent: true, opacity: 0.55, depthWrite: false
        }));
      p.rotation.x = -Math.PI / 2;
      p.visible = false;
      grp.add(p);
      prints.push({ mesh: p, t: 0 });
    }
    let printHead = 0;

    // --- aurora: ignites on constellation complete ---
    function auroraTex() {
      const c = document.createElement('canvas');
      c.width = 256; c.height = 64;
      const g = c.getContext('2d');
      const lg = g.createLinearGradient(0, 0, 0, 64);
      lg.addColorStop(0, 'rgba(0,0,0,0)');
      lg.addColorStop(0.4, 'rgba(80,255,190,.5)');
      lg.addColorStop(0.7, 'rgba(120,160,255,.35)');
      lg.addColorStop(1, 'rgba(0,0,0,0)');
      g.fillStyle = lg; g.fillRect(0, 0, 256, 64);
      return new THREE.CanvasTexture(c);
    }
    const auroras = [];
    for (let i = 0; i < 3; i++) {
      const m = new THREE.Mesh(new THREE.PlaneGeometry(180, 22),
        new THREE.MeshStandardMaterial({
          map: auroraTex(), transparent: true, opacity: 0,
          emissive: '#5fffc0', emissiveIntensity: 0.8,
          depthWrite: false, side: THREE.DoubleSide
        }));
      m.position.set((i - 1) * 40, 42 + i * 7, -70 - i * 22);
      m.rotation.x = 0.25;
      grp.add(m);
      auroras.push(m);
    }
    let auroraOn = false;

    // ============ ENDGAME (unlocks after both tasks) ============
    // find the highest terrain point on a coarse grid for the summit monument
    let sx0 = 0, sz0 = 0, sh0 = -Infinity;
    for (let gx = -SIZE / 2 + 20; gx <= SIZE / 2 - 20; gx += 8) {
      for (let gz = -SIZE / 2 + 20; gz <= SIZE / 2 - 20; gz += 8) {
        const hh = height(gx, gz);
        if (hh > sh0) { sh0 = hh; sx0 = gx; sz0 = gz; }
      }
    }
    const monument = new THREE.Group();
    const obeliskMat = new THREE.MeshStandardMaterial({
      color: '#2a3a52', emissive: '#12408a', emissiveIntensity: 0.35, metalness: 0.7, roughness: 0.3
    });
    const obelisk = new THREE.Mesh(new THREE.CylinderGeometry(0.16, 0.55, 4.2, 4), obeliskMat);
    obelisk.position.y = 2.1;
    obelisk.rotation.y = Math.PI / 4;
    monument.add(obelisk);
    const orb = new THREE.Mesh(new THREE.IcosahedronGeometry(0.55, 1),
      new THREE.MeshStandardMaterial({ color: '#ffe08a', emissive: '#ff9b2e', emissiveIntensity: 0.4, metalness: 0.4, roughness: 0.2 }));
    orb.position.y = 4.6;
    monument.add(orb);
    monument.add(glowSprite('rgba(255,180,80,.5)', 4.5));
    monument.position.set(sx0, sh0, sz0);
    monument.visible = false;
    grp.add(monument);
    let monReached = false, monLit = 0;

    // 5 relics — glowing artifacts scattered far and wide, appear post-completion
    const relicMat = new THREE.MeshStandardMaterial({
      color: '#ff8ad0', emissive: '#e83fa8', emissiveIntensity: 1.4, metalness: 0.3, roughness: 0.2
    });
    const relics = [];
    for (let i = 0; i < 5; i++) {
      const a = (i / 5) * Math.PI * 2 + 0.6;
      const d = 40 + (i % 2) * 30;
      const x = Math.cos(a) * d, z = Math.sin(a) * d;
      const y0 = height(x, z);
      const node = new THREE.Group();
      const gem = new THREE.Mesh(new THREE.IcosahedronGeometry(0.4, 0), relicMat);
      node.add(gem);
      node.add(glowSprite('rgba(255,138,208,.7)', 2.4));
      node.position.set(x, y0 + 1.0, z);
      node.visible = false;
      grp.add(node);
      relics.push({ node, gem, x, z, y0, taken: false, ph: i * 1.3 });
    }
    let endgameOn = false;

    scene.add(grp);

    return {
      group: grp,
      height,
      bound: SIZE / 2 - 12,
      banner,
      shardTotal: shards.length,
      ringTotal: rings.length,
      colliders,

      // nearest still-active objective to (x,z); returns {x,z,y,kind} or null
      nearestGoal(px, pz) {
        let best = null, bd = Infinity;
        for (const s of shards) {
          if (s.taken) continue;
          const d = (px - s.x) * (px - s.x) + (pz - s.z) * (pz - s.z);
          if (d < bd) { bd = d; best = { x: s.x, z: s.z, y: s.y0, kind: 'shard' }; }
        }
        // if all shards gone, point at remaining rings
        if (!best) {
          for (const r of rings) {
            if (r.passed) continue;
            const d = (px - r.x) * (px - r.x) + (pz - r.z) * (pz - r.z);
            if (d < bd) { bd = d; best = { x: r.x, z: r.z, y: r.y, kind: 'ring' }; }
          }
        }
        // endgame: relics, then the summit monument
        if (!best && endgameOn) {
          for (const rl of relics) {
            if (rl.taken) continue;
            const d = (px - rl.x) * (px - rl.x) + (pz - rl.z) * (pz - rl.z);
            if (d < bd) { bd = d; best = { x: rl.x, z: rl.z, y: rl.y0, kind: 'relic' }; }
          }
          if (!best && !monReached) {
            const d = (px - sx0) * (px - sx0) + (pz - sz0) * (pz - sz0);
            bd = d; best = { x: sx0, z: sz0, y: sh0, kind: 'summit' };
          }
        }
        if (best) best.dist = Math.sqrt(bd);
        return best;
      },

      // nearest geyser to (x,z) within range, for proximity hints
      nearestGeyser(px, pz) {
        let best = null, bd = Infinity;
        for (const gy of geysers) {
          const d = Math.hypot(px - gy.x, pz - gy.z);
          if (d < bd) { bd = d; best = { x: gy.x, z: gy.z, dist: d }; }
        }
        return best;
      },

      resetQuest() {
        shards.forEach((s) => { s.taken = false; s.node.visible = true; });
        rings.forEach((r) => { r.passed = false; r.torus.material.emissiveIntensity = 1.1; });
        prints.forEach((p) => { p.mesh.visible = false; });
        auroraOn = false;
        auroras.forEach((a) => { a.material.opacity = 0; });
        endgameOn = false;
        monReached = false; monLit = 0;
        monument.visible = false;
        relics.forEach((r) => { r.taken = false; r.node.visible = false; });
      },

      igniteAurora() { auroraOn = true; },

      // called once both tasks are done — reveals relics + summit monument
      unlockEndgame() {
        endgameOn = true;
        monument.visible = true;
        relics.forEach((r) => { r.node.visible = true; });
        return { summit: { x: monument.position.x, z: monument.position.z, y: sh0 }, relicTotal: relics.length };
      },
      get summit() { return { x: sx0, z: sz0, y: sh0 }; },

      print(x, z, angle) {
        const p = prints[printHead++ % PRINTS];
        p.mesh.position.set(x, height(x, z) + 0.02, z);
        p.mesh.rotation.z = -angle;
        p.mesh.material.opacity = 0.5;
        p.mesh.visible = true;
        p.t = 0;
      },

      // returns events that happened this frame
      quest(px, py, pz, air, dt, t) {
        const ev = { shard: null, ring: null, geyser: false, shardsLeft: 0, ringsLeft: 0, relic: null, relicsLeft: 0, summit: false };

        for (const s of shards) {
          if (s.taken) { ev.shardsLeft += 0; } else ev.shardsLeft++;
          if (!s.node.visible) continue;
          s.node.rotation.y += dt * 1.4;
          s.node.position.y = s.y0 + 0.9 + Math.sin(t * 2 + s.ph) * 0.18;
          s.pillar.material.opacity = 0.09 + Math.sin(t * 1.6 + s.ph) * 0.05;
          if (!s.taken) {
            const d = Math.hypot(px - s.x, pz - s.z);
            if (d < 1.5 && Math.abs(py - s.y0) < 2.2) {
              s.taken = true;
              s.node.visible = false;
              ev.shard = s.node.position;
              ev.shardsLeft--;
            }
          }
        }

        for (const r of rings) {
          if (!r.passed) ev.ringsLeft++;
          r.node.rotation.y += dt * (r.passed ? 0.2 : 0.9);
          r.node.position.y = r.y + Math.sin(t * 1.8 + r.ph) * 0.12;
          if (!r.passed && air) {
            const d = Math.hypot(px - r.x, pz - r.z);
            if (d < 1.15 && Math.abs((py + 1.0) - r.node.position.y) < 1.0) {
              r.passed = true;
              r.torus.material.emissiveIntensity = 0.25;
              ev.ring = r.node.position;
            }
          }
        }

        for (const gy of geysers) {
          gy.cool -= dt;
          const arr = gy.pts.geometry.attributes.position.array;
          for (let i = 0; i < gy.seeds.length; i++) {
            const k = (t * 0.5 + gy.seeds[i]) % 1;
            arr[i * 3] = (gy.seeds[i] - 0.5) * 0.9 * (0.4 + k);
            arr[i * 3 + 1] = k * 4.2;
            arr[i * 3 + 2] = ((gy.seeds[i] * 7) % 1 - 0.5) * 0.9 * (0.4 + k);
          }
          gy.pts.geometry.attributes.position.needsUpdate = true;
          if (gy.cool <= 0 && !air) {
            const d = Math.hypot(px - gy.x, pz - gy.z);
            if (d < 1.6) { gy.cool = 2.0; ev.geyser = true; }
          }
        }

        for (const p of prints) {
          if (!p.mesh.visible) continue;
          p.t += dt;
          p.mesh.material.opacity = Math.max(0, 0.5 - p.t * 0.055);
          if (p.t > 9) p.mesh.visible = false;
        }

        if (endgameOn) {
          for (const rl of relics) {
            if (!rl.taken) ev.relicsLeft++;
            if (!rl.node.visible) continue;
            rl.node.rotation.y += dt * 1.8;
            rl.gem.rotation.x += dt * 1.2;
            rl.node.position.y = rl.y0 + 1.0 + Math.sin(t * 2.2 + rl.ph) * 0.22;
            if (!rl.taken) {
              const d = Math.hypot(px - rl.x, pz - rl.z);
              if (d < 1.6 && Math.abs(py - rl.y0) < 2.4) {
                rl.taken = true;
                rl.node.visible = false;
                ev.relic = rl.node.position;
                ev.relicsLeft--;
              }
            }
          }
          // summit monument: reach the top, orb lights up
          orb.rotation.y += dt * 0.7;
          if (!monReached) {
            const d = Math.hypot(px - monument.position.x, pz - monument.position.z);
            if (d < 3.2 && Math.abs(py - sh0) < 3.5) {
              monReached = true;
              ev.summit = true;
            }
          } else {
            monLit = Math.min(1, monLit + dt * 0.7);
            orb.material.emissiveIntensity = 0.4 + monLit * 2.6 + Math.sin(t * 4) * 0.3 * monLit;
            obeliskMat.emissiveIntensity = 0.35 + monLit * 1.4;
          }
        }

        if (auroraOn) {
          auroras.forEach((a, i) => {
            a.material.opacity = Math.min(0.75, a.material.opacity + dt * 0.25);
            a.rotation.z = Math.sin(t * 0.22 + i * 1.7) * 0.05;
            a.position.y = 42 + i * 7 + Math.sin(t * 0.35 + i) * 1.6;
          });
        }
        return ev;
      },

      update(t) {
        banner.rotation.y = Math.sin(t * 1.4) * 0.22;
        for (const f of flora) {
          f.stem.rotation.z = Math.sin(t * 1.1 + f.ph) * 0.12;
          f.stem.rotation.x = Math.cos(t * 0.9 + f.ph) * 0.08;
        }
      }
    };
  }

  return { build, height };
})();

/* ===== src/orbit.js ===== */
/* APPROACH — stage 5 orbital descent. TANGENT's gameplay (orbit → tangent release →
   capture, sweet-spot perfects, decaying orbits, burn/void deaths) reskinned for
   OUTERSTELLAR: transparent 2D canvas over the live 3D starfield. 10 captures = landing. */
const ORBIT = (() => {
  const TAU = Math.PI * 2;
  const clamp = (v, a, b) => v < a ? a : (v > b ? b : v);
  const angDiff = (x) => { x = (x % TAU + TAU) % TAU; return x > Math.PI ? x - TAU : x; };

  const CYAN = '127,214,255', GOLD = '255,215,107', REDC = '255,95,107', INKC = '242,244,247';

  function create(canvas, hooks) {
    const cx = canvas.getContext('2d');
    let W = 0, H = 0, DPR = 1;
    const TARGET = 10;

    let running = false, done = false, dead = false;
    let wells = [], camY = 0;
    const player = { mode: 'orbit', wi: 0, th: -Math.PI / 2, r: 60, dirO: 1, x: 0, y: 0, vx: 0, vy: 0 };
    let lastWell = -1, releasedOnce = false;
    let hops = 0, perfect = 0, perfStreak = 0;
    let freeze = 0, shake = 0, tGlob = 0, doneAt = 0;
    let parts = [], rings = [], trail = [];

    const omega = () => Math.min(3.8, 2.3 + hops * 0.13);
    const decay = () => Math.min(24, 11 + hops * 1.3);

    function resize() {
      DPR = Math.min(2, window.devicePixelRatio || 1);
      W = window.innerWidth; H = window.innerHeight;
      canvas.width = W * DPR; canvas.height = H * DPR;
    }
    window.addEventListener('resize', () => { if (running) resize(); });

    function makeWell(x, y) {
      return {
        x0: x, x, y,
        ringR: clamp(60 - hops * 1.2, 46, 60) * (0.92 + Math.random() * 0.16),
        coreR: 10, sweetA: Math.random() * TAU,
        swAmp: hops >= 6 ? 12 + Math.random() * 16 : 0,
        swSp: 0.5 + Math.random() * 0.5, ph: Math.random() * TAU
      };
    }
    function topWellY() {
      let m = 1e9;
      for (const w of wells) m = Math.min(m, w.y);
      return m === 1e9 ? 0 : m;
    }
    function spawnAhead() {
      while (wells.length === 0 || topWellY() > camY - H * 1.2) {
        if (wells.length === 0) { wells.push(makeWell(W / 2, 0)); continue; }
        let prev = null, py = 1e9;
        for (const w of wells) if (w.y < py) { py = w.y; prev = w; }
        const dy = 160 + Math.random() * 80, dx = (Math.random() * 2 - 1) * 160;
        wells.push(makeWell(clamp(prev.x0 + dx, 72, W - 72), prev.y - dy));
      }
      for (let i = wells.length - 1; i >= 0; i--) {
        if (wells[i].y > camY + H * 1.7 && i !== player.wi && wells.length > 3) {
          wells.splice(i, 1);
          if (player.wi > i) player.wi--;
          if (lastWell > i) lastWell--; else if (lastWell === i) lastWell = -1;
        }
      }
    }
    const curWell = () => wells[player.wi];
    function syncOrbitPos() {
      const w = curWell();
      player.x = w.x + Math.cos(player.th) * player.r;
      player.y = w.y + Math.sin(player.th) * player.r;
    }

    function burst(x, y, n, col, spd) {
      const nn = CFG.reduced ? Math.floor(n / 3) : n;
      for (let i = 0; i < nn; i++) {
        const a = Math.random() * TAU, s = spd * (0.3 + Math.random() * 0.7);
        parts.push({ x, y, vx: Math.cos(a) * s, vy: Math.sin(a) * s, t: 0, tt: 0.35 + Math.random() * 0.4, r: 1.2 + Math.random() * 1.8, c: col });
      }
    }
    const ringFx = (x, y, c, sp) => rings.push({ x, y, c, sp, t: 0 });

    function start() {
      resize();
      wells = []; camY = -H * 0.58;
      hops = 0; perfect = 0; perfStreak = 0;
      done = false; dead = false; freeze = 0; shake = 0;
      parts = []; rings = []; trail = [];
      lastWell = -1; releasedOnce = false;
      spawnAhead();
      player.mode = 'orbit'; player.wi = 0; player.th = -Math.PI / 2;
      player.dirO = Math.random() < 0.5 ? 1 : -1; player.r = wells[0].ringR;
      syncOrbitPos();
      running = true;
    }
    function stop() { running = false; }

    function release() {
      const v = clamp(omega() * player.r, 160, 330);
      player.vx = -Math.sin(player.th) * v * player.dirO;
      player.vy = Math.cos(player.th) * v * player.dirO;
      player.mode = 'fly';
      lastWell = player.wi;
      releasedOnce = true;
      burst(player.x, player.y, 6, CYAN, 120);
      AUDIO.whoosh();
    }

    function capture(i, dist) {
      const w = wells[i];
      const rx = player.x - w.x, ry = player.y - w.y;
      player.dirO = (rx * player.vy - ry * player.vx) >= 0 ? 1 : -1;
      player.th = Math.atan2(ry, rx);
      player.r = Math.max(dist, w.coreR + 10);
      player.mode = 'orbit'; player.wi = i;
      syncOrbitPos();

      const isPerf = Math.abs(angDiff(player.th - w.sweetA)) < 0.38;
      hops++;
      if (isPerf) { perfect++; perfStreak++; } else perfStreak = 0;

      freeze = isPerf ? 0.09 : 0.05;
      shake = Math.min(9, shake + (isPerf ? 4.5 : 2.2) * (CFG.reduced ? 0.3 : 1));
      burst(player.x, player.y, isPerf ? 15 : 8, isPerf ? GOLD : CYAN, 220);
      ringFx(w.x, w.y, isPerf ? GOLD : INKC, isPerf ? 300 : 220);
      if (isPerf) AUDIO.perfect(hops); else AUDIO.hit(hops);
      hooks.onCapture && hooks.onCapture(isPerf, hops, perfStreak,
        { x: player.x, y: player.y - camY });

      if (hops >= TARGET) {
        done = true; doneAt = 0;
        burst(player.x, player.y, 40, GOLD, 300);
        ringFx(player.x, player.y, GOLD, 460);
        AUDIO.fanfare(true);
      }
    }

    function die(kind) {
      if (dead || done) return;
      dead = true;
      burst(player.x, player.y, 26, REDC, 320);
      burst(player.x, player.y, 12, INKC, 220);
      ringFx(player.x, player.y, REDC, 300);
      shake = Math.min(15, 13 * (CFG.reduced ? 0.3 : 1));
      AUDIO.miss(); AUDIO.boom();
      hooks.onDead && hooks.onDead(kind);
    }

    function tap() {
      if (!running || done || dead) return;
      if (player.mode === 'orbit') release();
    }

    function update(dt) {
      if (!running) return;
      tGlob += dt;
      shake *= Math.pow(0.0005, dt);
      for (const w of wells) {
        w.x = w.x0 + (w.swAmp ? Math.sin(tGlob * w.swSp + w.ph) * w.swAmp : 0);
      }
      for (let i = trail.length - 1; i >= 0; i--) { trail[i].t += dt; if (trail[i].t > 0.3) trail.splice(i, 1); }
      for (let i = parts.length - 1; i >= 0; i--) {
        const p = parts[i]; p.t += dt;
        p.x += p.vx * dt; p.y += p.vy * dt;
        p.vx *= Math.exp(-dt * 3); p.vy *= Math.exp(-dt * 3);
        if (p.t > p.tt) parts.splice(i, 1);
      }
      for (let i = rings.length - 1; i >= 0; i--) { rings[i].t += dt; if (rings[i].t > 0.5) rings.splice(i, 1); }

      if (done) {
        doneAt += dt;
        if (doneAt > 1.1) { running = false; hooks.onDone && hooks.onDone({ hops, perfect }); }
        return;
      }
      if (dead) return;
      if (freeze > 0) { freeze -= dt; return; }

      if (player.mode === 'orbit') {
        player.th += omega() * player.dirO * dt;
        if (releasedOnce) player.r -= decay() * dt;
        syncOrbitPos();
        if (player.r <= curWell().coreR + 4) { die('burn'); return; }
      } else {
        player.x += player.vx * dt;
        player.y += player.vy * dt;
        let bi = -1, bd = 1e9;
        for (let i = 0; i < wells.length; i++) {
          if (i === lastWell) continue;
          const d = Math.hypot(player.x - wells[i].x, player.y - wells[i].y);
          if (d < bd) { bd = d; bi = i; }
        }
        if (bi >= 0) {
          const w = wells[bi];
          if (bd < w.coreR + 5) { die('burn'); return; }
          if (bd < w.ringR + 20) capture(bi, bd);
        }
        if (player.x < -40 || player.x > W + 40 || player.y > camY + H + 50 || bd > H * 1.5) { die('void'); return; }
      }

      trail.push({ x: player.x, y: player.y, t: 0 });
      if (trail.length > 24) trail.shift();

      const desired = player.y - H * 0.58;
      if (desired < camY) camY += (desired - camY) * (1 - Math.exp(-dt * 6));
      spawnAhead();
    }

    function render() {
      if (!running && !dead) return;
      cx.setTransform(DPR, 0, 0, DPR, 0, 0);
      cx.clearRect(0, 0, W, H);   // transparent — 3D space shows through

      cx.save();
      const sh = CFG.reduced ? 0 : shake;
      cx.translate((Math.random() * 2 - 1) * sh, (Math.random() * 2 - 1) * sh - camY);

      // wells
      for (let i = 0; i < wells.length; i++) {
        const w = wells[i];
        if (w.y < camY - 120 || w.y > camY + H + 120) continue;
        const active = i === player.wi && player.mode === 'orbit';

        // orbit ring
        cx.strokeStyle = 'rgba(' + CYAN + ',' + (active ? 0.9 : 0.45) + ')';
        cx.lineWidth = active ? 2 : 1.3;
        cx.shadowColor = 'rgba(' + CYAN + ',.8)';
        cx.shadowBlur = active ? 14 : 6;
        cx.beginPath(); cx.arc(w.x, w.y, w.ringR, 0, TAU); cx.stroke();
        cx.shadowBlur = 0;

        // decayed orbit (player's actual radius, when shrunk)
        if (active && releasedOnce && player.r < w.ringR - 2) {
          cx.strokeStyle = 'rgba(' + REDC + ',.5)';
          cx.setLineDash([3, 5]);
          cx.beginPath(); cx.arc(w.x, w.y, player.r, 0, TAU); cx.stroke();
          cx.setLineDash([]);
        }

        // burn core
        const g = cx.createRadialGradient(w.x, w.y, 0, w.x, w.y, w.coreR * 2.2);
        g.addColorStop(0, 'rgba(' + REDC + ',.95)');
        g.addColorStop(0.5, 'rgba(' + REDC + ',.35)');
        g.addColorStop(1, 'rgba(' + REDC + ',0)');
        cx.fillStyle = g;
        cx.beginPath(); cx.arc(w.x, w.y, w.coreR * 2.2, 0, TAU); cx.fill();

        // sweet mark — gold arc + tick
        cx.strokeStyle = 'rgba(' + GOLD + ',.95)';
        cx.lineWidth = 3;
        cx.shadowColor = 'rgba(' + GOLD + ',.9)'; cx.shadowBlur = 10;
        cx.beginPath(); cx.arc(w.x, w.y, w.ringR, w.sweetA - 0.3, w.sweetA + 0.3); cx.stroke();
        cx.shadowBlur = 0;
        const mx = w.x + Math.cos(w.sweetA) * w.ringR, my = w.y + Math.sin(w.sweetA) * w.ringR;
        cx.fillStyle = 'rgba(' + GOLD + ',1)';
        cx.beginPath(); cx.arc(mx, my, 3.4, 0, TAU); cx.fill();
      }

      // tangent guide while orbiting
      if (player.mode === 'orbit' && !done && !dead) {
        const tx = -Math.sin(player.th) * player.dirO, ty = Math.cos(player.th) * player.dirO;
        cx.strokeStyle = 'rgba(' + INKC + ',.35)';
        cx.lineWidth = 1.2;
        cx.setLineDash([2, 8]);
        cx.beginPath();
        cx.moveTo(player.x + tx * 12, player.y + ty * 12);
        cx.lineTo(player.x + tx * 230, player.y + ty * 230);
        cx.stroke();
        cx.setLineDash([]);
      }

      // trail
      for (const t of trail) {
        const a = 1 - t.t / 0.3;
        cx.fillStyle = 'rgba(' + CYAN + ',' + (a * 0.5) + ')';
        cx.beginPath(); cx.arc(t.x, t.y, 2.2 * a, 0, TAU); cx.fill();
      }

      // particles
      for (const p of parts) {
        const a = 1 - p.t / p.tt;
        cx.fillStyle = 'rgba(' + p.c + ',' + a + ')';
        cx.beginPath(); cx.arc(p.x, p.y, p.r * a + 0.4, 0, TAU); cx.fill();
      }
      // expanding rings
      for (const r of rings) {
        const k = r.t / 0.5;
        cx.strokeStyle = 'rgba(' + r.c + ',' + (1 - k) + ')';
        cx.lineWidth = 2 * (1 - k) + 0.5;
        cx.beginPath(); cx.arc(r.x, r.y, r.sp * r.t + 6, 0, TAU); cx.stroke();
      }

      // player
      cx.fillStyle = 'rgba(' + INKC + ',1)';
      cx.shadowColor = 'rgba(' + CYAN + ',1)'; cx.shadowBlur = 12;
      cx.beginPath(); cx.arc(player.x, player.y, 4.2, 0, TAU); cx.fill();
      cx.shadowBlur = 0;

      cx.restore();
    }

    return {
      start, stop, update, render, tap, resize,
      get done() { return done; },
      get dead() { return dead; },
      get running() { return running; },
      get stats() { return { hops, perfect, target: TARGET, streak: perfStreak }; },
      // test hooks
      _player: player,
      _wells: () => wells,
      _cam: () => camY
    };
  }

  return { create };
})();

/* ===== src/ship.js ===== */
/* Rocket: 4 silhouettes from primitives, PBR, thruster fire, damage smoke. */
const SHIP = (() => {
  function panelTex(hex) {
    const S = 256;
    const c = document.createElement('canvas');
    c.width = c.height = S;
    const g = c.getContext('2d');
    g.fillStyle = hex; g.fillRect(0, 0, S, S);
    g.strokeStyle = 'rgba(0,0,0,.22)'; g.lineWidth = 1;
    for (let y = 0; y < S; y += 32) { g.beginPath(); g.moveTo(0, y); g.lineTo(S, y); g.stroke(); }
    for (let x = 0; x < S; x += 64) { g.beginPath(); g.moveTo(x, 0); g.lineTo(x, S); g.stroke(); }
    for (let i = 0; i < 240; i++) {
      g.fillStyle = `rgba(0,0,0,${Math.random() * 0.10})`;
      g.fillRect(Math.random() * S, Math.random() * S, 2, 2);
    }
    g.fillStyle = 'rgba(255,255,255,.10)';
    g.fillRect(0, 0, S, 5);
    const t = new THREE.CanvasTexture(c);
    t.wrapS = t.wrapT = THREE.RepeatWrapping;
    return t;
  }

  function firePoints(color, count, size) {
    const geo = new THREE.BufferGeometry();
    const p = new Float32Array(count * 3);
    for (let i = 0; i < count; i++) { p[i * 3] = 0; p[i * 3 + 1] = 0; p[i * 3 + 2] = 0; }
    geo.setAttribute('position', new THREE.BufferAttribute(p, 3));
    const c = document.createElement('canvas');
    c.width = c.height = 64;
    const g = c.getContext('2d');
    const rg = g.createRadialGradient(32, 32, 0, 32, 32, 32);
    rg.addColorStop(0, 'rgba(255,255,255,1)');
    rg.addColorStop(0.3, color);
    rg.addColorStop(1, 'rgba(0,0,0,0)');
    g.fillStyle = rg; g.fillRect(0, 0, 64, 64);
    const mat = new THREE.PointsMaterial({
      size, map: new THREE.CanvasTexture(c), transparent: true, depthWrite: false,
      blending: THREE.AdditiveBlending, opacity: 0.9
    });
    return new THREE.Points(geo, mat);
  }

  function build(cfg) {
    const hull = CFG.palettes.ship[cfg.ship];
    const body = CFG.bodies[cfg.body];
    const flame = CFG.palettes.flame[cfg.flame];

    const mat = new THREE.MeshStandardMaterial({
      color: hull, map: panelTex(hull), metalness: 0.8, roughness: 0.35
    });
    const dark = new THREE.MeshStandardMaterial({ color: '#1a1d24', metalness: 0.9, roughness: 0.4 });
    const glass = new THREE.MeshStandardMaterial({
      color: '#8fd8ff', metalness: 0.1, roughness: 0.05, emissive: '#2b6f96', emissiveIntensity: 0.5
    });

    const g = new THREE.Group();
    let len = 3.2, rad = 0.55, noseLen = 1.3;
    if (body === 'stubby') { len = 2.2; rad = 0.78; noseLen = 0.9; }
    if (body === 'needle') { len = 4.2; rad = 0.38; noseLen = 1.9; }
    if (body === 'retro') { len = 3.0; rad = 0.66; noseLen = 1.5; }

    const fuselage = new THREE.Mesh(new THREE.CylinderGeometry(rad, rad * 0.95, len, 28), mat);
    fuselage.castShadow = true;
    g.add(fuselage);

    const nose = new THREE.Mesh(new THREE.ConeGeometry(rad, noseLen, 28), mat);
    nose.position.y = len / 2 + noseLen / 2;
    nose.castShadow = true;
    g.add(nose);

    if (body === 'retro') {
      const band = new THREE.Mesh(new THREE.CylinderGeometry(rad * 1.04, rad * 1.04, 0.22, 28), dark);
      band.position.y = len * 0.18;
      g.add(band);
      const band2 = band.clone(); band2.position.y = -len * 0.18; g.add(band2);
    }

    // cockpit window
    const win = new THREE.Mesh(new THREE.SphereGeometry(rad * 0.42, 20, 16), glass);
    win.position.set(0, len * 0.3, rad * 0.86);
    win.scale.set(1, 0.8, 0.55);
    g.add(win);

    // fins
    const finCount = body === 'needle' ? 3 : 4;
    const finH = body === 'stubby' ? 0.7 : 0.95;
    for (let i = 0; i < finCount; i++) {
      const fin = new THREE.Mesh(new THREE.BoxGeometry(0.09, finH, rad * 1.5), mat);
      fin.castShadow = true;
      const a = (i / finCount) * Math.PI * 2;
      fin.position.set(Math.cos(a) * rad * 0.85, -len / 2 + finH * 0.35, Math.sin(a) * rad * 0.85);
      fin.rotation.y = -a;
      fin.rotation.x = 0.16;
      g.add(fin);
    }

    // engine bell
    const bell = new THREE.Mesh(new THREE.CylinderGeometry(rad * 0.5, rad * 0.95, 0.6, 24, 1, true), dark);
    bell.position.y = -len / 2 - 0.28;
    bell.material.side = THREE.DoubleSide;
    g.add(bell);

    // thruster fire + smoke
    const FIRE_N = 90;
    const fire = firePoints(flame, FIRE_N, 0.5);
    fire.position.y = -len / 2 - 0.5;
    g.add(fire);
    const fireV = [];
    for (let i = 0; i < FIRE_N; i++) fireV.push({ t: Math.random(), sp: 3 + Math.random() * 4 });

    const SMOKE_N = 60;
    const smoke = firePoints('rgba(180,190,200,.8)', SMOKE_N, 0.85);
    smoke.material.blending = THREE.NormalBlending;
    smoke.material.opacity = 0;
    g.add(smoke);
    const smokeV = [];
    for (let i = 0; i < SMOKE_N; i++) smokeV.push({ t: Math.random(), sp: 0.6 + Math.random() * 1.2, off: new THREE.Vector3((Math.random() - 0.5), (Math.random() - 0.5) * len, (Math.random() - 0.5)) });

    let throttle = 1, damage = 0;

    return {
      obj: g,
      nose,
      length: len,
      setThrottle(v) { throttle = v; },
      setDamage(d) { damage = Math.max(0, Math.min(1, d)); },
      update(dt) {
        const fp = fire.geometry.attributes.position.array;
        for (let i = 0; i < FIRE_N; i++) {
          const v = fireV[i];
          v.t += dt * v.sp * (0.4 + throttle);
          if (v.t > 1) { v.t = 0; }
          const k = v.t;
          const spread = 0.28 * k * (0.5 + throttle);
          fp[i * 3] = (Math.random() - 0.5) * spread;
          fp[i * 3 + 1] = -k * 2.1 * (0.4 + throttle * 0.9);
          fp[i * 3 + 2] = (Math.random() - 0.5) * spread;
        }
        fire.geometry.attributes.position.needsUpdate = true;
        fire.material.opacity = 0.35 + throttle * 0.6;
        fire.material.size = 0.35 + throttle * 0.35;

        smoke.material.opacity = damage * 0.5;
        if (damage > 0.01) {
          const sp = smoke.geometry.attributes.position.array;
          for (let i = 0; i < SMOKE_N; i++) {
            const v = smokeV[i];
            v.t += dt * v.sp * 0.4;
            if (v.t > 1) v.t = 0;
            sp[i * 3] = v.off.x + (Math.random() - 0.5) * 0.2;
            sp[i * 3 + 1] = v.off.y - v.t * 3.0;
            sp[i * 3 + 2] = v.off.z - v.t * 1.2;
          }
          smoke.geometry.attributes.position.needsUpdate = true;
          smoke.material.size = 0.5 + damage * 0.9;
        }
      }
    };
  }

  return { build, panelTex };
})();

